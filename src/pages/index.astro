---
// ─── Home Page ─────────────────────────────────────────────────
// White liquid glass landing page assembling all sections.

import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import GameCard from "../components/GameCard.astro";
import FilterBar from "../components/FilterBar.astro";
import ProgressTracker from "../components/ProgressTracker.astro";
import Timeline from "../components/Timeline.astro";
import StatsCards from "../components/StatsCards.astro";
import OverallProgress from "../components/OverallProgress.astro";
import RecentUpdates from "../components/RecentUpdates.astro";
import FAQ from "../components/FAQ.astro";
import LBKLauncher from "../components/LBKLauncher.astro";
import Support from "../components/Support.astro";
import Footer from "../components/Footer.astro";
import GameModal from "../components/GameModal.astro";
import { games } from "../data/games";

// Use the order from src/data/games.ts directly — that file is the source of truth.
const sortedGames = games;
---

<Layout>
  <Header />

  <main class="flex-1">
    <Hero />

    <!-- Projects Section -->
    <section id="projects" class="pt-12 pb-24 sm:pt-16 sm:pb-28 relative">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10" data-animate>
          <span class="lb-section-eyebrow mb-4">Локалізації</span>
          <h2 class="text-3xl sm:text-4xl font-black text-slate-900 mt-3 mb-3">
            Наші проєкти
          </h2>
          <p class="text-slate-500 max-w-lg mx-auto">
            Ігри, над локалізацією яких ми працюємо
          </p>
        </div>

        <FilterBar />

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 sm:gap-6" id="games-grid">
          {sortedGames.map((game) => <GameCard game={game} />)}
        </div>
      </div>
    </section>

    <!-- Analytics -->
    <section class="py-20 sm:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12" data-animate>
          <span class="lb-section-eyebrow mb-4">Цифри команди</span>
          <h2 class="text-3xl sm:text-4xl font-black text-slate-900 mt-3 mb-3">
            Аналітика
          </h2>
          <p class="text-slate-500 max-w-lg mx-auto">
            Статистика прогресу та досягнень локалізацій
          </p>
        </div>

        <div class="mb-12">
          <StatsCards />
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <ProgressTracker />
          <Timeline />
        </div>
      </div>
    </section>

    <OverallProgress />
    <RecentUpdates />
    <LBKLauncher />
    <Support />
    <FAQ />
  </main>

  <Footer />
  <GameModal />
</Layout>
