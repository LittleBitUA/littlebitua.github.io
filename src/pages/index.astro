---
// ─── Home Page ─────────────────────────────────────────────────
// White liquid glass landing page assembling all sections.

import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import GameCard from "../components/GameCard.astro";
import FilterBar from "../components/FilterBar.astro";
import Pipeline from "../components/Pipeline.astro";
import ProgressTracker from "../components/ProgressTracker.astro";
import Timeline from "../components/Timeline.astro";
import StatsCards from "../components/StatsCards.astro";
import HowToPlay from "../components/HowToPlay.astro";
import FAQ from "../components/FAQ.astro";
import LBKLauncher from "../components/LBKLauncher.astro";
import Support from "../components/Support.astro";
import Footer from "../components/Footer.astro";
import GameModal from "../components/GameModal.astro";
import { games } from "../data/games";

// Use the order from src/data/games.ts directly — that file is the source of truth.
const sortedGames = games;
---

<Layout>
  <Header />

  <main class="flex-1">
    <Hero />

    <!-- Projects Section -->
    <section id="projects" class="pt-12 pb-24 sm:pt-16 sm:pb-28 relative">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10" data-animate>
          <span class="lb-section-eyebrow mb-4">Локалізації</span>
          <h2 class="text-3xl sm:text-4xl font-black text-slate-900 mt-3 mb-3">
            Наші проєкти
          </h2>
          <p class="text-slate-500 max-w-lg mx-auto">
            Ігри, над локалізацією яких ми працюємо
          </p>
        </div>

        <FilterBar />

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 sm:gap-6" id="games-grid">
          {sortedGames.map((game) => <GameCard game={game} />)}
        </div>
      </div>
    </section>

    <Pipeline />

    <!-- Analytics — компактно: StatsCards + tab-перемикач (Прогрес / Релізи) -->
    <section class="py-20 sm:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12" data-animate>
          <span class="lb-section-eyebrow mb-4">Цифри команди</span>
          <h2 class="text-3xl sm:text-4xl font-black text-slate-900 mt-3 mb-3">
            Аналітика
          </h2>
          <p class="text-slate-500 max-w-lg mx-auto">
            Статистика прогресу та досягнень локалізацій
          </p>
        </div>

        <div class="mb-10">
          <StatsCards />
        </div>

        <!-- Tab switcher between ProgressTracker and Timeline -->
        <div class="flex items-center justify-center gap-1.5 mb-6" data-animate>
          <button
            type="button"
            class="analytics-tab analytics-tab--active"
            data-analytics-tab="progress"
            aria-controls="analytics-progress"
            aria-selected="true"
          >
            Прогрес
          </button>
          <button
            type="button"
            class="analytics-tab"
            data-analytics-tab="timeline"
            aria-controls="analytics-timeline"
            aria-selected="false"
          >
            Релізи
          </button>
        </div>

        <div id="analytics-progress" class="analytics-panel">
          <ProgressTracker />
        </div>
        <div id="analytics-timeline" class="analytics-panel hidden">
          <Timeline />
        </div>

        <div class="flex items-center justify-center mt-8">
          <a href="/updates" class="lb-btn lb-btn--ghost !text-sm">
            Хроніка оновлень
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <HowToPlay />
    <LBKLauncher />
    <Support />
    <FAQ />
  </main>

  <Footer />
  <GameModal />
</Layout>

<style>
  .analytics-tab {
    padding: 0.5rem 1.25rem;
    font-size: 0.78rem;
    font-weight: 700;
    border-radius: 999px;
    border: 1px solid rgba(15, 23, 42, 0.10);
    background: rgba(255, 255, 255, 0.7);
    color: #475569;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
  }
  .analytics-tab:hover {
    background: rgba(255, 255, 255, 0.95);
    border-color: rgba(99, 102, 241, 0.35);
    color: #0f172a;
    transform: translateY(-1px);
  }
  .analytics-tab--active,
  .analytics-tab--active:hover {
    background-color: #6366f1;
    color: #fff;
    border-color: transparent;
    box-shadow: 0 8px 18px -10px rgba(99, 102, 241, 0.55);
    transform: none;
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>(".analytics-tab");
  const panels = document.querySelectorAll<HTMLElement>(".analytics-panel");

  tabs.forEach((btn) => {
    btn.addEventListener("click", () => {
      const target = btn.dataset.analyticsTab;
      if (!target) return;

      tabs.forEach((b) => {
        const isActive = b === btn;
        b.classList.toggle("analytics-tab--active", isActive);
        b.setAttribute("aria-selected", String(isActive));
      });

      panels.forEach((panel) => {
        panel.classList.toggle("hidden", panel.id !== `analytics-${target}`);
      });
    });
  });
</script>
