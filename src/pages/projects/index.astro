---
// ─── Projects Page ──────────────────────────────────────────
// All localization projects with filtering.

import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import GameCard from "../../components/GameCard.astro";
import FilterBar from "../../components/FilterBar.astro";
import GameModal from "../../components/GameModal.astro";
import { games } from "../../data/games";
---

<Layout
  title="Проєкти — «Little Bit» Українська локалізація відеоігор"
  description="Усі проєкти локалізації команди «Little Bit». Слідкуйте за прогресом перекладу ігор українською."
>
  <Header />

  <main class="flex-1">
    <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-28 pb-6">
      <ol class="flex items-center gap-2 text-xs text-slate-500">
        <li><a href="/" class="hover:text-indigo-600 transition-colors">Головна</a></li>
        <li>
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </li>
        <li class="text-slate-900 font-semibold">Проєкти</li>
      </ol>
    </nav>

    <section class="pb-24 relative">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10" data-animate>
          <span class="lb-section-eyebrow mb-4">Усі проєкти</span>
          <h1 class="text-3xl sm:text-4xl font-black text-slate-900 mt-3 mb-3">
            Локалізації Little Bit
          </h1>
          <p class="text-slate-500 max-w-lg mx-auto">
            Ігри, над локалізацією яких ми працюємо
          </p>
        </div>

        <FilterBar />

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 sm:gap-6" id="games-grid">
          {games.map((game) => <GameCard game={game} />)}
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <GameModal />
</Layout>
