---
// ─── Project Detail Page ─────────────────────────────────────────
// White liquid glass detail page for a single localization project.

import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ProgressBar from "../../components/ProgressBar.astro";
import StatusBadge from "../../components/StatusBadge.astro";
import Tag from "../../components/Tag.astro";
import { games, STATUS_LABELS } from "../../data/games";
import { getBadge } from "../../data/gameBadges";
import "@fortawesome/fontawesome-free/css/all.css";
import type { Game } from "../../data/games";
import {
  SITE_URL,
  getCanonicalUrl,
  generateGameStructuredData,
  generateBreadcrumbs,
  generateKeywords,
} from "../../utils/seo";
import { marked } from "marked";

export function getStaticPaths() {
  return games.map((game) => ({
    params: { slug: game.id },
    props: { game },
  }));
}

const { game } = Astro.props as { game: Game };

const pageTitle = `${game.title} — Українська локалізація | Little Bit`;
const pageDescription = game.detailedDescription || game.description;
const canonicalUrl = getCanonicalUrl(`projects/${game.id}`);
const ogImage = game.cover.startsWith("http") ? game.cover : `${SITE_URL}${game.cover}`;
const keywords = generateKeywords(game);

const gameStructuredData = generateGameStructuredData(game);
const breadcrumbsData = generateBreadcrumbs([
  { name: "Головна", url: SITE_URL },
  { name: "Проєкти", url: `${SITE_URL}/projects` },
  { name: game.title, url: canonicalUrl },
]);

const structuredData = `[${gameStructuredData},${breadcrumbsData}]`;

const badge = getBadge(game.id);

const STATUS_PILL: Record<string, string> = {
  done: "text-emerald-700 bg-emerald-50 border-emerald-200",
  "early-access": "text-sky-700 bg-sky-50 border-sky-200",
  "in-progress": "text-violet-700 bg-violet-50 border-violet-200",
  fundraising: "text-amber-700 bg-amber-50 border-amber-200",
  planned: "text-slate-700 bg-slate-50 border-slate-200",
};

const currentIndex = games.findIndex((g) => g.id === game.id);
const prevGame = currentIndex > 0 ? games[currentIndex - 1] : null;
const nextGame = currentIndex < games.length - 1 ? games[currentIndex + 1] : null;
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
  ogType="product"
  keywords={keywords}
  structuredData={structuredData}
>
  <Header />

  <main class="flex-1">
    <!-- Breadcrumbs -->
    <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-28 pb-4">
      <ol class="flex items-center gap-2 text-xs text-slate-500 flex-wrap">
        <li><a href="/" class="hover:text-indigo-600 transition-colors">Головна</a></li>
        <li><svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg></li>
        <li><a href="/projects" class="hover:text-indigo-600 transition-colors">Проєкти</a></li>
        <li><svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg></li>
        <li class="text-slate-900 font-semibold">{game.title}</li>
      </ol>
    </nav>

    <!-- Hero -->
    <section class="relative overflow-hidden">
      <!-- Blurred cover backdrop (single static blur, no extra backdrop-filter layer) -->
      <div class="absolute inset-0 -z-10" aria-hidden="true">
        <img
          src={game.cover}
          alt=""
          class="absolute inset-0 w-full h-full object-cover scale-110 blur-3xl opacity-30"
          loading="eager"
          decoding="async"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-white/65 via-white/75 to-white/40"></div>
      </div>

      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
        <div class="lb-glass-strong p-6 sm:p-8">
          <div class="grid grid-cols-1 lg:grid-cols-[300px_1fr] gap-8 items-start">

            <div class="mx-auto lg:mx-0 w-full max-w-[300px]">
              <div class="relative aspect-[2/3] rounded-2xl overflow-hidden border border-white/80 shadow-[0_30px_60px_-30px_rgba(15,23,42,0.45)]">
                <img src={game.cover} alt={game.title} class="absolute inset-0 w-full h-full object-cover" />
                <div class="absolute top-3 left-3 flex flex-col gap-1.5">
                  <span class={`inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-bold rounded-lg border bg-white/95 shadow-sm ${STATUS_PILL[game.status]}`}>
                    {STATUS_LABELS[game.status]}
                  </span>
                  {game.version && (
                    <span class="inline-flex items-center px-3 py-1.5 text-xs font-bold rounded-lg border border-white/80 bg-white/95 shadow-sm text-slate-700">
                      v{game.version}
                    </span>
                  )}
                </div>
              </div>

              {badge && (
                <div class="mt-3">
                  <StatusBadge badge={badge} variant="card" />
                </div>
              )}
            </div>

            <div class="space-y-6">
              <div>
                <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-slate-900 leading-tight mb-3">
                  {game.title}
                </h1>
                <p class="text-slate-700 text-base sm:text-lg leading-relaxed">
                  {game.detailedDescription || game.description}
                </p>
              </div>

              <!-- Progress -->
              <div class="space-y-2">
                <div class="flex items-center justify-between text-sm">
                  <span class="text-slate-500 font-semibold uppercase tracking-wide text-xs">Прогрес локалізації</span>
                  <span class="text-slate-900 font-bold tabular-nums">{game.progress}%</span>
                </div>
                <ProgressBar percent={game.progress} showLabel={false} />
              </div>

              <!-- Stats -->
              {game.stats && (
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                  {game.stats.totalLines && (
                    <div class="lb-glass-soft p-3.5">
                      <p class="text-2xl font-black text-slate-900 tabular-nums">{game.stats.totalLines.toLocaleString("uk-UA")}</p>
                      <p class="text-xs text-slate-500 mt-1">Рядків тексту</p>
                    </div>
                  )}
                  {game.stats.totalWords && (
                    <div class="lb-glass-soft p-3.5">
                      <p class="text-2xl font-black text-slate-900 tabular-nums">{game.stats.totalWords.toLocaleString("uk-UA")}</p>
                      <p class="text-xs text-slate-500 mt-1">Слів</p>
                    </div>
                  )}
                  {game.gameYear && (
                    <div class="lb-glass-soft p-3.5">
                      <p class="text-2xl font-black text-slate-900 tabular-nums">{game.gameYear}</p>
                      <p class="text-xs text-slate-500 mt-1">Рік випуску</p>
                    </div>
                  )}
                  {game.releaseDate && (
                    <div class="lb-glass-soft p-3.5">
                      <p class="text-2xl font-black text-emerald-600 tabular-nums">
                        {new Date(game.releaseDate).toLocaleDateString("uk-UA", { day: "numeric", month: "short" })}
                      </p>
                      <p class="text-xs text-slate-500 mt-1">Дата релізу</p>
                    </div>
                  )}
                </div>
              )}

              <!-- Tags -->
              {game.tags && game.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5">
                  {game.tags.map((tag) => <Tag label={tag} />)}
                </div>
              )}

              <!-- Screenshots -->
              {game.screenshots && game.screenshots.length > 0 && (
                <div class="grid grid-cols-3 sm:grid-cols-5 gap-2">
                  {game.screenshots.map((src, i) => (
                    <div
                      class="gallery-thumb group relative rounded-xl overflow-hidden border border-white/80 hover:border-indigo-300 cursor-pointer transition-colors shadow-sm"
                      data-index={i}
                      role="button"
                      tabindex="0"
                    >
                      <img src={src} alt={`Скріншот ${i + 1}`} class="w-full h-auto block" loading="lazy" />
                      <div class="absolute inset-0 bg-slate-900/0 group-hover:bg-slate-900/15 transition-colors flex items-center justify-center">
                        <svg class="w-6 h-6 text-white opacity-0 group-hover:opacity-100 transition-opacity drop-shadow-lg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM10.5 7.5v6m3-3h-6" />
                        </svg>
                      </div>
                    </div>
                  ))}
                </div>
              )}

              <!-- Fundraising blocks -->
              {game.fundraisingCompleted && (
                <div class="rounded-2xl border border-emerald-200 bg-emerald-50/85 p-5">
                  <div class="flex items-center gap-2 mb-2">
                    <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <span class="text-sm font-bold text-emerald-700">Збір коштів завершено!</span>
                  </div>
                  <p class="text-sm text-emerald-900/85">
                    Спільнота зібрала необхідну суму. Дякуємо! Переклад активно розвивається.
                  </p>
                </div>
              )}

              {game.fundraisingGoal && (
                <div class="rounded-2xl border border-amber-200 bg-amber-50/85 p-5">
                  <div class="flex items-center gap-2 mb-2">
                    <svg class="w-4 h-4 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                    </svg>
                    <span class="text-sm font-bold text-amber-700">Збір коштів</span>
                  </div>
                  <p class="text-sm text-amber-900/85 mb-4">
                    {game.fundraisingDescription || "Ми збираємо кошти на текстову локалізацію цієї гри. Підтримайте проєкт!"}
                  </p>
                  {(() => {
                    const raised = game.fundraisingRaised ?? 0;
                    const goal = game.fundraisingGoal ?? 0;
                    const pct = goal > 0 ? Math.min(100, Math.round((raised / goal) * 100)) : 0;
                    return (
                      <div class="mb-4">
                        <div class="flex items-center justify-between mb-1.5">
                          <span class="text-xs text-amber-700/80">Зібрано</span>
                          <span class="text-xs font-bold text-amber-700 tabular-nums">
                            {raised.toLocaleString("uk-UA")} ₴ з {goal.toLocaleString("uk-UA")} ₴ · {pct}%
                          </span>
                        </div>
                        <div class="h-2 rounded-full bg-amber-100 overflow-hidden">
                          <div
                            id="fundraising-bar"
                            class="h-full rounded-full bg-gradient-to-r from-amber-400 to-orange-400"
                            style="width: 0%"
                            data-target={`${pct}`}
                          ></div>
                        </div>
                      </div>
                    );
                  })()}
                  <a
                    href={game.donateUrl}
                    target="_blank" rel="noopener noreferrer"
                    class="lb-btn !text-sm"
                    style="color:#b45309; background: rgba(245,158,11,0.15); border: 1px solid rgba(245,158,11,0.4);"
                  >
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                    </svg>
                    Задонатити
                  </a>
                </div>
              )}

              <!-- Action buttons -->
              <div class="flex flex-wrap gap-3 pt-2">
                {game.downloadUrl && (
                  <a
                    href={game.downloadUrl}
                    target="_blank" rel="noopener noreferrer"
                    class="lb-btn lb-btn--primary"
                  >
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                    </svg>
                    Завантажити локалізацію
                  </a>
                )}
                {game.steamUrl && (
                  <a
                    href={game.steamUrl}
                    target="_blank" rel="noopener noreferrer"
                    class="lb-btn lb-btn--ghost"
                  >
                    <i class="fa-brands fa-steam"></i>
                    Steam
                  </a>
                )}
                <a
                  href={game.donateUrl}
                  target="_blank" rel="noopener noreferrer"
                  class="lb-btn lb-btn--soft"
                >
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                  </svg>
                  Підтримати
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Lightbox -->
    {game.screenshots && game.screenshots.length > 0 && (
      <div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/85 backdrop-blur-md">
        <button id="lb-close" type="button" class="absolute top-4 right-4 z-10 p-2 text-white/80 hover:text-white transition-colors cursor-pointer">
          <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
        <button id="lb-prev" type="button" class="absolute left-4 top-1/2 -translate-y-1/2 z-10 p-2 text-white/80 hover:text-white transition-colors cursor-pointer">
          <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button id="lb-next" type="button" class="absolute right-4 top-1/2 -translate-y-1/2 z-10 p-2 text-white/80 hover:text-white transition-colors cursor-pointer">
          <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>
        <div class="flex items-center justify-center w-full h-full p-12">
          <img id="lb-img" src="" alt="" class="max-w-full max-h-full object-contain rounded-xl shadow-2xl" />
        </div>
        <div id="lb-counter" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-sm text-white/70 tabular-nums"></div>
      </div>
    )}

    <!-- Content sections -->
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 space-y-12">
      <!-- FAQ + Install tabs -->
      {game.faq && game.faq.length > 0 ? (
        <section>
          <div class="flex gap-1 mb-6 border-b border-slate-200/70">
            <button
              data-tab="faq"
              class="tab-btn px-5 py-2.5 text-sm font-bold rounded-t-lg transition-colors text-slate-900 border-b-2 border-indigo-500 -mb-px"
            >FAQ</button>
            <button
              data-tab="install"
              class="tab-btn px-5 py-2.5 text-sm font-bold rounded-t-lg transition-colors text-slate-500 border-b-2 border-transparent -mb-px hover:text-slate-900"
            >Встановлення</button>
          </div>

          <div id="panel-faq" class="tab-panel space-y-3">
            {game.faq.map((item) => (
              <div class="lb-glass p-5 sm:p-6">
                <p class="font-bold text-slate-900 mb-2">{item.question}</p>
                <p class="text-sm text-slate-600 leading-relaxed">{item.answer}</p>
              </div>
            ))}
          </div>

          <div id="panel-install" class="tab-panel hidden">
            {game.installInstructions ? (
              <div
                class="prose lb-prose prose-sm sm:prose-base max-w-none lb-glass p-6 sm:p-8"
                set:html={marked(game.installInstructions)}
              />
            ) : (
              <div class="lb-glass p-6 sm:p-8 flex items-center gap-3">
                <svg class="w-5 h-5 text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <p class="text-sm text-slate-600">
                  Локалізація наразі у роботі. Інструкції з'являться, коли переклад буде доступний для завантаження.
                </p>
              </div>
            )}
          </div>

          <script>
            const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
            const tabPanels = document.querySelectorAll<HTMLElement>('.tab-panel');
            tabBtns.forEach((btn) => {
              btn.addEventListener('click', () => {
                const target = btn.dataset.tab;
                tabBtns.forEach((b) => {
                  const active = b.dataset.tab === target;
                  b.classList.toggle('text-slate-900', active);
                  b.classList.toggle('border-indigo-500', active);
                  b.classList.toggle('text-slate-500', !active);
                  b.classList.toggle('border-transparent', !active);
                });
                tabPanels.forEach((panel) => {
                  panel.classList.toggle('hidden', panel.id !== `panel-${target}`);
                });
              });
            });
          </script>
        </section>
      ) : game.installInstructions ? (
        <section>
          <h2 class="text-2xl font-black text-slate-900 mb-6">Встановлення</h2>
          <div
            class="prose lb-prose prose-sm sm:prose-base max-w-none lb-glass p-6 sm:p-8"
            set:html={marked(game.installInstructions)}
          />
        </section>
      ) : (
        <section>
          <h2 class="text-2xl font-black text-slate-900 mb-6">Встановлення</h2>
          <div class="lb-glass p-6 sm:p-8 flex items-center gap-3">
            <svg class="w-5 h-5 text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p class="text-sm text-slate-600">
              Локалізація наразі у роботі. Інструкції з'являться, коли переклад буде доступний.
            </p>
          </div>
        </section>
      )}

      <!-- Progress History Chart -->
      {game.progressHistory && game.progressHistory.length > 0 && (
        <section>
          <h2 class="text-2xl font-black text-slate-900 mb-6">Історія прогресу</h2>
          <div class="lb-glass p-6 sm:p-8">
            <canvas id="progress-chart" class="max-h-[300px]"></canvas>
          </div>
        </section>
      )}
    </div>

    <!-- Prev/next nav -->
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {prevGame ? (
          <a href={`/projects/${prevGame.id}`} class="lb-glass lb-lift p-4 group flex items-center gap-4">
            <svg class="w-5 h-5 text-slate-400 group-hover:text-indigo-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            <div class="flex-1 min-w-0">
              <p class="text-xs text-slate-500 mb-1">Попередній проєкт</p>
              <p class="font-bold text-slate-900 truncate">{prevGame.title}</p>
            </div>
          </a>
        ) : <div />}

        {nextGame ? (
          <a href={`/projects/${nextGame.id}`} class="lb-glass lb-lift p-4 group flex items-center gap-4 text-right">
            <div class="flex-1 min-w-0">
              <p class="text-xs text-slate-500 mb-1">Наступний проєкт</p>
              <p class="font-bold text-slate-900 truncate">{nextGame.title}</p>
            </div>
            <svg class="w-5 h-5 text-slate-400 group-hover:text-indigo-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ) : <div />}
      </div>
    </div>
  </main>

  <Footer />

  {game.screenshots && game.screenshots.length > 0 && (
    <script define:vars={{ screenshots: game.screenshots }}>
      const lightbox = document.getElementById("lightbox");
      const lbImg = document.getElementById("lb-img");
      const lbCounter = document.getElementById("lb-counter");
      let currentIndex = 0;

      function showImage(index) {
        currentIndex = ((index % screenshots.length) + screenshots.length) % screenshots.length;
        lbImg.src = screenshots[currentIndex];
        lbImg.alt = `Скріншот ${currentIndex + 1}`;
        lbCounter.textContent = `${currentIndex + 1} / ${screenshots.length}`;
      }

      function openLightbox(index) {
        showImage(index);
        lightbox.classList.remove("hidden");
        lightbox.classList.add("flex");
        document.body.style.overflow = "hidden";
      }

      function closeLightbox() {
        lightbox.classList.add("hidden");
        lightbox.classList.remove("flex");
        document.body.style.overflow = "";
      }

      document.querySelectorAll(".gallery-thumb").forEach((thumb) => {
        thumb.addEventListener("click", () => {
          openLightbox(parseInt(thumb.dataset.index, 10));
        });
      });

      document.getElementById("lb-close").addEventListener("click", closeLightbox);
      document.getElementById("lb-prev").addEventListener("click", () => showImage(currentIndex - 1));
      document.getElementById("lb-next").addEventListener("click", () => showImage(currentIndex + 1));

      lightbox.addEventListener("click", (e) => {
        if (e.target === lightbox) closeLightbox();
      });

      document.addEventListener("keydown", (e) => {
        if (lightbox.classList.contains("hidden")) return;
        if (e.key === "Escape") closeLightbox();
        if (e.key === "ArrowLeft") showImage(currentIndex - 1);
        if (e.key === "ArrowRight") showImage(currentIndex + 1);
      });
    </script>
  )}

  {game.fundraisingGoal && (
    <script>
      const bar = document.getElementById("fundraising-bar");
      if (bar) {
        const target = parseInt(bar.dataset.target, 10);
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              bar.style.transition = "width 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94)";
              bar.style.width = target + "%";
              observer.disconnect();
            }
          });
        }, { threshold: 0.5 });
        observer.observe(bar);
      }
    </script>
  )}

  {game.progressHistory && game.progressHistory.length > 0 && (
    <script define:vars={{ progressHistory: game.progressHistory }}>
      import {
        Chart, LineController, LineElement, PointElement,
        LinearScale, TimeScale, CategoryScale, Title, Tooltip, Legend, Filler,
      } from "chart.js";

      Chart.register(LineController, LineElement, PointElement, LinearScale, TimeScale, CategoryScale, Title, Tooltip, Legend, Filler);

      const ctx = document.getElementById("progress-chart");
      new Chart(ctx, {
        type: "line",
        data: {
          labels: progressHistory.map((entry) =>
            new Date(entry.date).toLocaleDateString("uk-UA", { day: "numeric", month: "short" })
          ),
          datasets: [{
            label: "Прогрес (%)",
            data: progressHistory.map((entry) => entry.progress),
            borderColor: "#6366f1",
            backgroundColor: "rgba(99, 102, 241, 0.1)",
            borderWidth: 2.5,
            fill: true,
            tension: 0.4,
            pointRadius: 5,
            pointHoverRadius: 7,
            pointBackgroundColor: "#6366f1",
            pointBorderColor: "#fff",
            pointBorderWidth: 2,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              backgroundColor: "rgba(255, 255, 255, 0.95)",
              titleColor: "#0f172a",
              bodyColor: "#1e293b",
              borderColor: "rgba(99, 102, 241, 0.2)",
              borderWidth: 1,
              padding: 12,
              displayColors: false,
              callbacks: { label: (context) => `${context.parsed.y}%` },
            },
          },
          scales: {
            y: {
              beginAtZero: true, max: 100,
              ticks: { callback: (v) => `${v}%`, color: "rgba(15, 23, 42, 0.55)" },
              grid: { color: "rgba(15, 23, 42, 0.06)" },
            },
            x: {
              ticks: { color: "rgba(15, 23, 42, 0.55)" },
              grid: { display: false },
            },
          },
        },
      });
    </script>
  )}
</Layout>
