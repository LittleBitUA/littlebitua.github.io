---
// ─── Updates Page ─────────────────────────────────────────────
// Хроніка оновлень — агрегована з progressHistory та lastUpdate
// усіх ігор. Друкована візуалізація RSS-стрічки.

import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getAllUpdates, formatUpdateDate, eventTone } from "../utils/updates";
import { SITE_URL } from "../utils/seo";

const events = getAllUpdates();

// Групуємо за роком-місяцем для зручної навігації.
const groups = new Map<string, typeof events>();
for (const e of events) {
  const key = e.date.slice(0, 7); // YYYY-MM
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(e);
}

function formatGroupHeader(yearMonth: string): string {
  const [y, m] = yearMonth.split("-").map(Number);
  return new Date(y, m - 1, 1).toLocaleDateString("uk-UA", {
    month: "long",
    year: "numeric",
  });
}

const canonicalUrl = `${SITE_URL}/updates`;
---

<Layout
  title="Хроніка оновлень — Little Bit"
  description="Усі оновлення проєктів локалізації Little Bit: прогрес перекладу, релізи, ранній доступ. Можна підписатися через RSS."
  canonicalUrl={canonicalUrl}
  ogType="website"
>
  <Header />

  <main class="flex-1">
    <!-- Breadcrumbs -->
    <nav class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pt-28 pb-4">
      <ol class="flex items-center gap-2 text-xs text-slate-500">
        <li><a href="/" class="hover:text-indigo-600 transition-colors">Головна</a></li>
        <li>
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </li>
        <li class="text-slate-900 font-semibold">Хроніка оновлень</li>
      </ol>
    </nav>

    <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-10">
      <div class="text-center mb-10" data-animate>
        <span class="lb-section-eyebrow mb-4">Усі оновлення</span>
        <h1 class="text-3xl sm:text-4xl font-black text-slate-900 mt-3 mb-3">
          Хроніка локалізацій
        </h1>
        <p class="text-slate-600 max-w-xl mx-auto">
          Кожен крок наших проєктів: прогрес перекладу, релізи, ранній доступ.
        </p>
        <div class="flex items-center justify-center mt-5">
          <a href="/projects" class="lb-btn lb-btn--ghost !text-sm">
            До проєктів
          </a>
        </div>
      </div>

      {events.length === 0 ? (
        <p class="text-center text-slate-500 py-16">Поки що немає подій.</p>
      ) : (
        <div class="space-y-10">
          {Array.from(groups.entries()).map(([key, monthEvents]) => (
            <div data-animate>
              <h2 class="text-center text-sm font-black uppercase tracking-widest text-slate-400 mb-5 sticky top-20 bg-white/70 backdrop-blur-md py-2 -mx-1 px-1 rounded-lg z-10">
                {formatGroupHeader(key)}
              </h2>
              <div class="relative pl-7">
                <div class="absolute left-[10px] top-2 bottom-2 w-px bg-gradient-to-b from-indigo-300 via-sky-300 to-transparent"></div>
                <div class="space-y-4">
                  {monthEvents.map((e) => {
                    const tone = eventTone(e.kind);
                    return (
                      <div class="relative">
                        <span class={`absolute -left-[19px] top-3 w-3 h-3 rounded-full ${tone.dot} ring-4 ring-white shadow-[0_4px_12px_-4px_rgba(15,23,42,0.3)]`}></span>
                        <a href={`/projects#game=${e.gameId}`} class="block lb-glass lb-lift p-4 sm:p-5 group">
                          <div class="flex items-start gap-4">
                            <img
                              src={e.gameCover}
                              alt={e.gameTitle}
                              class="w-14 h-20 sm:w-16 sm:h-24 rounded-lg object-cover shrink-0 border border-white/80"
                              loading="lazy"
                              decoding="async"
                            />
                            <div class="min-w-0 flex-1">
                              <div class="flex items-start justify-between gap-3 flex-wrap mb-1.5">
                                <span class={`inline-flex items-center px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider rounded-md border ${tone.badge}`}>
                                  {tone.label}
                                </span>
                                <time class="text-xs text-slate-500 shrink-0" datetime={e.date}>
                                  {formatUpdateDate(e.date)}
                                </time>
                              </div>
                              <h3 class="font-bold text-slate-900 group-hover:text-indigo-600 transition-colors text-base leading-snug mb-1">
                                {e.title}
                              </h3>
                              <p class="text-sm text-slate-600 line-clamp-2">{e.description}</p>
                              {typeof e.progress === "number" && (
                                <div class="flex items-center gap-2 mt-2">
                                  <div class="flex-1 h-1.5 rounded-full bg-slate-200/80 overflow-hidden max-w-[180px]">
                                    <div
                                      class="h-full rounded-full"
                                      style={`width: ${e.progress}%; background: ${e.progress >= 100 ? "#10b981" : "linear-gradient(90deg,#6366f1,#0ea5e9)"};`}
                                    ></div>
                                  </div>
                                  <span class="text-[11px] font-bold tabular-nums text-slate-700">{e.progress}%</span>
                                </div>
                              )}
                            </div>
                          </div>
                        </a>
                      </div>
                    );
                  })}
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </section>
  </main>

  <Footer />
</Layout>
