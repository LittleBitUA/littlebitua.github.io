---
// ─── Tag Component ─────────────────────────────────────────────
// Light glass chip — clickable filter for tags.

export interface Props {
  label: string;
  color?: string;
}

const { label, color } = Astro.props;
---

<button
  type="button"
  data-tag-filter={label}
  class="inline-flex items-center px-2.5 py-1 text-[11px] font-medium rounded-lg cursor-pointer select-none
         text-slate-600 border border-white/70 bg-white/65
         hover:bg-indigo-50 hover:text-indigo-700 hover:border-indigo-200
         transition-colors duration-200"
  style={color ? `border-color: ${color}33; color: ${color}` : undefined}
>
  {label}
</button>
