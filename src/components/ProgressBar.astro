---
// ─── ProgressBar Component ─────────────────────────────────────
// Glass-style animated progress bar.

export interface Props {
  percent: number;
  showLabel?: boolean;
  size?: "sm" | "md" | "lg";
  /** Optional accent color (hex/rgb). If omitted — auto color by percent. */
  color?: string;
}

const { percent, showLabel = true, size = "md", color } = Astro.props;
const clampedPercent = Math.max(0, Math.min(100, percent));

const heightMap = { sm: "h-1.5", md: "h-2.5", lg: "h-3.5" };

function getGradient(p: number, colorOverride?: string): string {
  if (colorOverride) return `linear-gradient(90deg, ${colorOverride}, ${colorOverride})`;
  // Завершено — зелений. Усе інше — єдиний accent-градієнт сайту.
  if (p >= 100) return "linear-gradient(90deg, #16a34a, #22d3ee)";
  return "linear-gradient(90deg, #6366f1, #818cf8 60%, #38bdf8)";
}
---

<div class="w-full">
  {showLabel && (
    <div class="flex justify-between items-center mb-1.5">
      <span class="text-[11px] font-semibold uppercase tracking-wider text-slate-500">Прогрес</span>
      <span class="text-xs font-bold tabular-nums text-slate-900">
        {clampedPercent}%
      </span>
    </div>
  )}

  <div class={`relative w-full rounded-full overflow-hidden ${heightMap[size]}`} style="background: rgba(15,23,42,0.07); box-shadow: 0 1px 0 rgba(255,255,255,0.7) inset;">
    <div
      class="lb-bar h-full rounded-full"
      style={`--progress-width: ${clampedPercent}%; background: ${getGradient(clampedPercent, color)};`}
      role="progressbar"
      aria-valuenow={clampedPercent}
      aria-valuemin={0}
      aria-valuemax={100}
    ></div>
  </div>
</div>

<style>
  .lb-bar {
    width: var(--progress-width);
    position: relative;
  }
  @media (prefers-reduced-motion: reduce) {
    .lb-bar { width: var(--progress-width); }
  }
</style>
