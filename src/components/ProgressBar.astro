---
// ─── ProgressBar Component ─────────────────────────────────────
// Liquid Glass — тонка скляна шкала з делікатним glow.
//   • Доріжка: ледь індигове прозоре скло.
//   • Заповнення: linear-gradient indigo → violet.
//   • Для md/lg розмірів — % показується прямо в полосці (білий поверх
//     заповнення, темний поверх доріжки), використовуючи clip-path
//     щоб обидві версії підписів стояли в одному місці.
//   • Для sm — без підпису, просто тонка лінія.

export interface Props {
  percent: number;
  showLabel?: boolean;
  size?: "sm" | "md" | "lg";
  /** Optional accent color (hex/rgb). If omitted — auto color by percent. */
  color?: string;
  /** Optional left-aligned inline label rendered inside the bar (md/lg only). */
  label?: string;
}

const { percent, showLabel = true, size = "md", color, label } = Astro.props;
const clampedPercent = Math.max(0, Math.min(100, percent));

// Висоти: sm — тонка декоративна, md/lg — достатньо для тексту всередині.
const heightMap = {
  sm: "h-1.5",
  md: "h-4",
  lg: "h-5",
};
const textSizeMap = {
  sm: "",
  md: "text-[10px]",
  lg: "text-[11px]",
};

const isDone = clampedPercent >= 100;

function getFillBackground(p: number, colorOverride?: string): string {
  if (colorOverride) return colorOverride;
  if (p >= 100) return "linear-gradient(90deg, #10b981, #14b8a6)";
  return "linear-gradient(90deg, #6366f1, #8b5cf6)";
}

const glow = isDone
  ? "0 0 14px -2px rgba(16,185,129,0.55), 0 0 4px rgba(16,185,129,0.45)"
  : "0 0 14px -2px rgba(99,102,241,0.55), 0 0 4px rgba(139,92,246,0.40)";

// Підпис всередині полоски — тільки для md/lg і коли showLabel === true
const showInline = showLabel && size !== "sm";
---

<div class="w-full">
  <div
    class={`lb-progress relative w-full rounded-full overflow-hidden ${heightMap[size]}`}
    style="background: rgba(99, 102, 241, 0.10); box-shadow: 0 1px 0 rgba(255,255,255,0.7) inset, 0 1px 2px rgba(15,23,42,0.04) inset;"
    role="progressbar"
    aria-valuenow={clampedPercent}
    aria-valuemin={0}
    aria-valuemax={100}
  >
    <!-- Fill -->
    <div
      class:list={["lb-bar absolute left-0 top-0 bottom-0 rounded-full", isDone && "is-done"]}
      style={`--progress-width: ${clampedPercent}%; background: ${getFillBackground(clampedPercent, color)}; box-shadow: ${glow};`}
    ></div>

    {showInline && (
      <>
        <!-- Підпис на доріжці (видно там, де ще нема заповнення) -->
        <span
          class={`lb-label-track absolute inset-0 flex items-center ${label ? "justify-between px-2.5" : "justify-end pr-2.5"} text-slate-700 ${textSizeMap[size]}`}
        >
          {label && <span class="font-semibold uppercase tracking-wider">{label}</span>}
          <span class="font-bold tabular-nums">{clampedPercent}%</span>
        </span>
        <!-- Підпис над заповненням (видно лише в межах залитої частини) -->
        <span
          class={`lb-label-fill absolute inset-0 flex items-center ${label ? "justify-between px-2.5" : "justify-end pr-2.5"} text-white ${textSizeMap[size]}`}
          style={`clip-path: inset(0 ${100 - clampedPercent}% 0 0);`}
        >
          {label && <span class="font-semibold uppercase tracking-wider">{label}</span>}
          <span class="font-bold tabular-nums">{clampedPercent}%</span>
        </span>
      </>
    )}
  </div>
</div>

<style>
  .lb-bar {
    width: var(--progress-width);
    transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    overflow: hidden;
  }
  /* Тонкий світловий блік, що "пливе" по заповненню — натяк на роботу,
     яка триває. На завершених полосках вимикається. */
  .lb-bar::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.55) 50%,
      transparent 100%
    );
    background-size: 40% 100%;
    background-repeat: no-repeat;
    background-position: -40% 0;
    animation: lbBarFlow 2.4s linear infinite;
    pointer-events: none;
    border-radius: inherit;
  }
  .lb-bar.is-done::after {
    animation: none;
    opacity: 0;
  }
  @keyframes lbBarFlow {
    to { background-position: 140% 0; }
  }
  .lb-label-track,
  .lb-label-fill {
    pointer-events: none;
    letter-spacing: 0.01em;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.4);
  }
  .lb-label-fill {
    text-shadow: 0 1px 1px rgba(15, 23, 42, 0.35);
    transition: clip-path 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @media (prefers-reduced-motion: reduce) {
    .lb-bar, .lb-label-fill { transition: none; }
    .lb-bar::after { animation: none; opacity: 0; }
  }
</style>
