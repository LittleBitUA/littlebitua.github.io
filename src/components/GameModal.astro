---
// ─── GameModal ────────────────────────────────────────────────
// Один модальний компонент для всіх ігор.
// Кожна гра рендериться як прихована панель; при кліку на "Детальніше"
// з будь-якої частини сайту вмикається відповідна панель у вікні.

import { games, STATUS_LABELS } from "../data/games";
import { getBadge } from "../data/gameBadges";
import StatusBadge from "./StatusBadge.astro";
import ProgressBar from "./ProgressBar.astro";
import Tag from "./Tag.astro";
import { marked } from "marked";

const STATUS_PILL: Record<string, string> = {
  done: "text-emerald-700 bg-emerald-50 border-emerald-200",
  "early-access": "text-sky-700 bg-sky-50 border-sky-200",
  "in-progress": "text-violet-700 bg-violet-50 border-violet-200",
  fundraising: "text-amber-700 bg-amber-50 border-amber-200",
  planned: "text-slate-700 bg-slate-50 border-slate-200",
};

function fmtDate(d?: string) {
  if (!d) return "";
  return new Date(d).toLocaleDateString("uk-UA", {
    day: "numeric", month: "long", year: "numeric",
  });
}
---

<!-- Modal shell -->
<div
  id="game-modal"
  class="fixed inset-0 z-[100] hidden items-center justify-center p-2 sm:p-6"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
>
  <div id="game-modal-backdrop" class="absolute inset-0 bg-slate-900/55 transition-opacity"></div>
  <div class="relative w-full max-w-5xl max-h-[94vh] flex flex-col rounded-3xl overflow-hidden lb-glass-strong">
    <button
      id="game-modal-close"
      class="absolute top-3 right-3 z-30 w-10 h-10 rounded-full bg-white/95 border border-white/80 text-slate-700 hover:bg-white hover:text-slate-900 shadow-md flex items-center justify-center transition-colors"
      aria-label="Закрити"
    >
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <div id="game-modal-scroll" class="overflow-y-auto overscroll-contain">
      <div id="game-modal-stage">
        {games.map((game) => {
          const badge = getBadge(game.id);
          const fundraisingPct = game.fundraisingGoal
            ? Math.min(100, Math.round(((game.fundraisingRaised ?? 0) / game.fundraisingGoal) * 100))
            : 0;
          return (
            <section
              class="game-detail-panel hidden"
              data-modal-game-id={game.id}
              aria-hidden="true"
            >
              <!-- Hero section -->
              <div class="relative overflow-hidden">
                <div class="absolute inset-0 -z-10" aria-hidden="true">
                  <img src={game.cover} alt="" class="absolute inset-0 w-full h-full object-cover scale-110 blur-2xl opacity-30" />
                  <div class="absolute inset-0 bg-gradient-to-b from-white/65 via-white/80 to-white/95"></div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-[260px_1fr] gap-6 p-6 sm:p-8">
                  <div class="mx-auto lg:mx-0 w-full max-w-[260px]">
                    <div class="relative aspect-[2/3] rounded-2xl overflow-hidden border border-white/80 shadow-[0_24px_50px_-22px_rgba(15,23,42,0.45)]">
                      <img src={game.cover} alt={game.title} class="absolute inset-0 w-full h-full object-cover" loading="lazy" decoding="async" />
                      <div class="absolute top-2.5 left-2.5 flex flex-col gap-1.5">
                        <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 text-[10px] font-bold rounded-lg border bg-white/95 shadow-sm ${STATUS_PILL[game.status]}`}>
                          {STATUS_LABELS[game.status]}
                        </span>
                        {game.version && (
                          <span class="inline-flex items-center px-2.5 py-1 text-[10px] font-bold rounded-lg border border-white/80 bg-white/95 text-slate-700 shadow-sm">
                            v{game.version}
                          </span>
                        )}
                      </div>
                      {badge && (
                        <div class="absolute bottom-0 left-0 right-0 z-10">
                          <StatusBadge badge={badge} variant="overlay" />
                        </div>
                      )}
                    </div>
                  </div>

                  <div class="space-y-5 min-w-0">
                    <div>
                      <h2 class="text-2xl sm:text-3xl font-black text-slate-900 leading-tight mb-2 break-words">
                        {game.title}
                      </h2>
                      <p class="text-slate-700 text-sm sm:text-base leading-relaxed">
                        {game.detailedDescription || game.description}
                      </p>
                    </div>

                    <div class="space-y-1.5">
                      <div class="flex items-center justify-between text-sm">
                        <span class="text-slate-500 font-semibold uppercase tracking-wide text-xs">Прогрес локалізації</span>
                        <span class="text-slate-900 font-bold tabular-nums">{game.progress}%</span>
                      </div>
                      <ProgressBar percent={game.progress} showLabel={false} />
                    </div>

                    {game.stageDetails && game.stageDetails.length > 0 && (
                      <div class="space-y-1.5">
                        {game.stageDetails.map((detail) => (
                          <div class="flex items-center gap-2">
                            <span class="text-[11px] font-semibold text-slate-500 w-[80px] flex-shrink-0 truncate">
                              {detail.label}
                            </span>
                            <div class="flex-1 h-1.5 rounded-full bg-slate-200/70 overflow-hidden">
                              <div
                                class="h-full rounded-full"
                                style={`width: ${detail.percent}%; background: ${detail.percent >= 100 ? "#16a34a" : detail.percent > 0 ? "linear-gradient(90deg,#6366f1,#0ea5e9)" : "rgba(100,116,139,0.6)"};`}
                              ></div>
                            </div>
                            <span class="text-[11px] font-bold tabular-nums text-slate-700 w-[34px] text-right">
                              {detail.percent}%
                            </span>
                          </div>
                        ))}
                      </div>
                    )}

                    {game.stats && (
                      <div class="grid grid-cols-2 sm:grid-cols-4 gap-2.5">
                        {game.stats.totalLines && (
                          <div class="lb-glass-soft p-3">
                            <p class="text-xl font-black text-slate-900 tabular-nums">{game.stats.totalLines.toLocaleString("uk-UA")}</p>
                            <p class="text-xs text-slate-500 mt-0.5">Рядків тексту</p>
                          </div>
                        )}
                        {game.stats.totalWords && (
                          <div class="lb-glass-soft p-3">
                            <p class="text-xl font-black text-slate-900 tabular-nums">{game.stats.totalWords.toLocaleString("uk-UA")}</p>
                            <p class="text-xs text-slate-500 mt-0.5">Слів</p>
                          </div>
                        )}
                        {game.gameYear && (
                          <div class="lb-glass-soft p-3">
                            <p class="text-xl font-black text-slate-900 tabular-nums">{game.gameYear}</p>
                            <p class="text-xs text-slate-500 mt-0.5">Рік випуску</p>
                          </div>
                        )}
                        {game.releaseDate && (
                          <div class="lb-glass-soft p-3">
                            <p class="text-xl font-black text-emerald-600 tabular-nums">
                              {new Date(game.releaseDate).toLocaleDateString("uk-UA", { day: "numeric", month: "short" })}
                            </p>
                            <p class="text-xs text-slate-500 mt-0.5">Дата релізу</p>
                          </div>
                        )}
                      </div>
                    )}

                    {game.tags && game.tags.length > 0 && (
                      <div class="flex flex-wrap gap-1.5">
                        {game.tags.map((tag) => <Tag label={tag} />)}
                      </div>
                    )}

                    {game.fundraisingCompleted && (
                      <div class="rounded-2xl border border-emerald-200 bg-emerald-50/85 p-4">
                        <div class="flex items-center gap-2 mb-1.5">
                          <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                          </svg>
                          <span class="text-sm font-bold text-emerald-700">Збір коштів завершено!</span>
                        </div>
                        <p class="text-xs text-emerald-900/80">Спільнота зібрала суму. Дякуємо!</p>
                      </div>
                    )}

                    {game.fundraisingGoal && (
                      <div class="rounded-2xl border border-amber-200 bg-amber-50/85 p-4">
                        <div class="flex items-center gap-2 mb-2">
                          <svg class="w-4 h-4 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                          </svg>
                          <span class="text-sm font-bold text-amber-700">Збір коштів</span>
                        </div>
                        {game.fundraisingDescription && (
                          <p class="text-xs text-amber-900/85 mb-3">{game.fundraisingDescription}</p>
                        )}
                        <div class="flex items-center justify-between mb-1">
                          <span class="text-[11px] text-amber-700/85">Зібрано</span>
                          <span class="text-[11px] font-bold text-amber-700 tabular-nums">
                            {(game.fundraisingRaised ?? 0).toLocaleString("uk-UA")} ₴ із {game.fundraisingGoal.toLocaleString("uk-UA")} ₴ · {fundraisingPct}%
                          </span>
                        </div>
                        <div class="h-2 rounded-full bg-amber-100 overflow-hidden mb-3">
                          <div class="h-full rounded-full bg-gradient-to-r from-amber-400 to-orange-400" style={`width: ${fundraisingPct}%`}></div>
                        </div>
                        <a
                          href={game.donateUrl}
                          target="_blank" rel="noopener noreferrer"
                          class="inline-flex items-center gap-2 px-4 py-2 text-xs font-bold rounded-xl"
                          style="color:#b45309; background: rgba(245,158,11,0.18); border: 1px solid rgba(245,158,11,0.4);"
                        >
                          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                          </svg>
                          Задонатити
                        </a>
                      </div>
                    )}

                    <div class="flex flex-wrap gap-2.5 pt-1">
                      {game.downloadUrl && (
                        <a
                          href={game.downloadUrl}
                          target="_blank" rel="noopener noreferrer"
                          class="lb-btn lb-btn--primary !text-sm"
                        >
                          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                          </svg>
                          Завантажити локалізацію
                        </a>
                      )}
                      {game.steamUrl && (
                        <a href={game.steamUrl} target="_blank" rel="noopener noreferrer" class="lb-btn lb-btn--ghost !text-sm">
                          <i class="fa-brands fa-steam"></i> Steam
                        </a>
                      )}
                      <a href={game.donateUrl} target="_blank" rel="noopener noreferrer" class="lb-btn lb-btn--soft !text-sm">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                        </svg>
                        Підтримати
                      </a>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Detail content -->
              <div class="px-6 pb-8 sm:px-8 sm:pb-10 space-y-8">

                {/* Screenshots */}
                {game.screenshots && game.screenshots.length > 0 && (
                  <div>
                    <h3 class="text-lg font-black text-slate-900 mb-3">Скріншоти</h3>
                    <div class="grid grid-cols-3 sm:grid-cols-5 gap-2">
                      {game.screenshots.map((src, i) => (
                        <a
                          href={src}
                          target="_blank" rel="noopener noreferrer"
                          class="relative rounded-xl overflow-hidden border border-white/80 hover:border-indigo-300 transition-colors shadow-sm block"
                          aria-label={`Скріншот ${i + 1}`}
                        >
                          <img src={src} alt={`Скріншот ${i + 1}`} class="w-full h-auto block" loading="lazy" decoding="async" />
                        </a>
                      ))}
                    </div>
                  </div>
                )}

                {/* FAQ */}
                {game.faq && game.faq.length > 0 && (
                  <div>
                    <h3 class="text-lg font-black text-slate-900 mb-3">Часті питання</h3>
                    <div class="space-y-2">
                      {game.faq.map((item) => (
                        <details class="lb-glass-soft p-4 cursor-pointer">
                          <summary class="flex items-center justify-between gap-3 font-semibold text-slate-900 list-none">
                            <span>{item.question}</span>
                            <span class="shrink-0 w-6 h-6 rounded-full bg-indigo-50 text-indigo-600 flex items-center justify-center transition-transform open-chevron">
                              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                              </svg>
                            </span>
                          </summary>
                          <p class="mt-2 text-sm text-slate-600 leading-relaxed">{item.answer}</p>
                        </details>
                      ))}
                    </div>
                  </div>
                )}

                {/* Install instructions */}
                {game.installInstructions && (
                  <div>
                    <h3 class="text-lg font-black text-slate-900 mb-3">Встановлення</h3>
                    <div
                      class="prose lb-prose prose-sm max-w-none lb-glass-soft p-5"
                      set:html={marked(game.installInstructions)}
                    />
                  </div>
                )}

                {/* Progress history (text list, no chart) */}
                {game.progressHistory && game.progressHistory.length > 0 && (
                  <div>
                    <h3 class="text-lg font-black text-slate-900 mb-3">Історія прогресу</h3>
                    <ul class="space-y-2">
                      {[...game.progressHistory].reverse().map((entry) => (
                        <li class="flex items-start gap-3 lb-glass-soft px-4 py-2.5">
                          <span class="text-xs font-bold tabular-nums text-indigo-600 w-12 shrink-0 mt-0.5">
                            {entry.progress}%
                          </span>
                          <div class="flex-1 min-w-0">
                            <p class="text-sm font-semibold text-slate-900">{entry.milestone || "—"}</p>
                            <p class="text-xs text-slate-500">{fmtDate(entry.date)}</p>
                          </div>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                {game.team && game.team.length > 0 && (
                  <div>
                    <h3 class="text-lg font-black text-slate-900 mb-3">Команда</h3>
                    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                      {game.team.map((m) => (
                        <li class="lb-glass-soft px-4 py-2.5">
                          <p class="text-sm font-semibold text-slate-900">{m.name}</p>
                          <p class="text-xs text-slate-500">{m.role}</p>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                {game.lastUpdate && (
                  <p class="text-xs text-slate-500 text-center pt-2">
                    Останнє оновлення: {fmtDate(game.lastUpdate)}
                  </p>
                )}
              </div>
            </section>
          );
        })}
      </div>
    </div>
  </div>
</div>

<style>
  #game-modal.is-open { display: flex; animation: lbModalFade 0.2s ease-out; }
  @keyframes lbModalFade { from { opacity: 0; } to { opacity: 1; } }

  .game-detail-panel.active { display: block; }
  .game-detail-panel { display: none; }

  details > summary { list-style: none; }
  details > summary::-webkit-details-marker { display: none; }
  details[open] .open-chevron { transform: rotate(180deg); }

  body.lb-modal-open { overflow: hidden; }
</style>

<script>
  const modal = document.getElementById("game-modal")!;
  const backdrop = document.getElementById("game-modal-backdrop")!;
  const closeBtn = document.getElementById("game-modal-close")!;
  const scroll = document.getElementById("game-modal-scroll") as HTMLElement;
  const panels = document.querySelectorAll<HTMLElement>(".game-detail-panel");

  function openModal(gameId: string) {
    let found = false;
    panels.forEach((panel) => {
      const match = panel.dataset.modalGameId === gameId;
      panel.classList.toggle("active", match);
      panel.setAttribute("aria-hidden", match ? "false" : "true");
      if (match) found = true;
    });
    if (!found) return;

    modal.classList.add("is-open");
    modal.classList.remove("hidden");
    modal.setAttribute("aria-hidden", "false");
    document.body.classList.add("lb-modal-open");
    scroll.scrollTop = 0;

    // Update URL hash for shareability without triggering navigation
    history.replaceState(null, "", `#game=${gameId}`);
  }

  function closeModal() {
    modal.classList.remove("is-open");
    modal.classList.add("hidden");
    modal.setAttribute("aria-hidden", "true");
    document.body.classList.remove("lb-modal-open");
    panels.forEach((p) => {
      p.classList.remove("active");
      p.setAttribute("aria-hidden", "true");
    });
    if (location.hash.startsWith("#game=")) {
      history.replaceState(null, "", location.pathname + location.search);
    }
  }

  // Delegated open trigger — any [data-game-detail] element opens the modal
  document.addEventListener("click", (e) => {
    const el = (e.target as HTMLElement).closest<HTMLElement>("[data-game-detail]");
    if (!el) return;
    e.preventDefault();
    e.stopPropagation();
    const id = el.dataset.gameDetail;
    if (id) openModal(id);
  });

  closeBtn.addEventListener("click", closeModal);
  backdrop.addEventListener("click", closeModal);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modal.classList.contains("is-open")) closeModal();
  });

  // Open via URL hash (#game=mgs-snake-eater)
  const hash = location.hash;
  if (hash.startsWith("#game=")) {
    const id = decodeURIComponent(hash.slice(6));
    requestAnimationFrame(() => openModal(id));
  }
</script>
