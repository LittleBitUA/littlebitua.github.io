---
// ─── StatsCards Component ──────────────────────────────────────
// Light glass stats grid.

import { games } from "../data/games";

const totalStats = games.reduce(
  (acc, game) => {
    if (game.stats) {
      acc.lines += game.stats.translatedLines || 0;
      acc.words += game.stats.totalWords || 0;
      acc.characters += game.stats.totalCharacters || 0;
    }
    return acc;
  },
  { lines: 0, words: 0, characters: 0 }
);

const earlyAccessCount = games.filter((g) => g.status === "early-access").length;
const inProgressCount = games.filter((g) => g.status === "in-progress" || g.status === "early-access").length;
const totalProjects = games.length;

function formatNumber(num: number): string {
  if (num >= 1_000_000) return `${(num / 1_000_000).toFixed(1)}M`;
  if (num >= 1_000) return `${(num / 1_000).toFixed(1)}K`;
  return num.toLocaleString("uk-UA");
}
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-5" data-animate-stagger>
  <!-- Total projects -->
  <div class="lb-glass lb-lift p-6">
    <div class="flex items-center justify-between mb-3">
      <div class="w-10 h-10 rounded-2xl bg-gradient-to-br from-indigo-500 to-violet-500 text-white flex items-center justify-center shadow-[0_8px_18px_-10px_rgba(99,102,241,0.6)]">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
        </svg>
      </div>
      <span class="text-[10px] font-bold uppercase tracking-[0.16em] text-indigo-500">Проєктів</span>
    </div>
    <p class="text-4xl font-black text-slate-900 mb-1 tabular-nums">{totalProjects}</p>
    <p class="text-xs text-slate-500">
      <span class="text-emerald-600 font-semibold">{earlyAccessCount} у ранньому доступі</span>,
      <span class="text-sky-600 font-semibold">{inProgressCount} у роботі</span>
    </p>
  </div>

  {totalStats.lines > 0 && (
    <div class="lb-glass lb-lift p-6">
      <div class="flex items-center justify-between mb-3">
        <div class="w-10 h-10 rounded-2xl bg-gradient-to-br from-sky-500 to-cyan-500 text-white flex items-center justify-center shadow-[0_8px_18px_-10px_rgba(14,165,233,0.6)]">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <span class="text-[10px] font-bold uppercase tracking-[0.16em] text-sky-500">Рядків</span>
      </div>
      <p class="text-4xl font-black text-slate-900 mb-1 tabular-nums">{formatNumber(totalStats.lines)}</p>
      <p class="text-xs text-slate-500">Перекладено тексту</p>
    </div>
  )}

  {totalStats.words > 0 && (
    <div class="lb-glass lb-lift p-6">
      <div class="flex items-center justify-between mb-3">
        <div class="w-10 h-10 rounded-2xl bg-gradient-to-br from-violet-500 to-fuchsia-500 text-white flex items-center justify-center shadow-[0_8px_18px_-10px_rgba(167,139,250,0.6)]">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
          </svg>
        </div>
        <span class="text-[10px] font-bold uppercase tracking-[0.16em] text-violet-500">Слів</span>
      </div>
      <p class="text-4xl font-black text-slate-900 mb-1 tabular-nums">{formatNumber(totalStats.words)}</p>
      <p class="text-xs text-slate-500">У всіх проєктах</p>
    </div>
  )}

  {totalStats.characters > 0 && (
    <div class="lb-glass lb-lift p-6">
      <div class="flex items-center justify-between mb-3">
        <div class="w-10 h-10 rounded-2xl bg-gradient-to-br from-emerald-500 to-teal-500 text-white flex items-center justify-center shadow-[0_8px_18px_-10px_rgba(16,185,129,0.6)]">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
        </div>
        <span class="text-[10px] font-bold uppercase tracking-[0.16em] text-emerald-500">Символів</span>
      </div>
      <p class="text-4xl font-black text-slate-900 mb-1 tabular-nums">{formatNumber(totalStats.characters)}</p>
      <p class="text-xs text-slate-500">Загалом</p>
    </div>
  )}
</div>
