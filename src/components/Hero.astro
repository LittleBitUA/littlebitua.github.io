---
// ─── Hero — White Liquid Glass Bento ─────────────────────────
// Світлий dashboard-style блок з прозорими картками й featured-каруселлю.

import { getOverallProgress, games, STATUS_LABELS } from "../data/games";

const overall = getOverallProgress();
const totalGames = games.length;
const earlyAccessCount = games.filter((g) => g.status === "early-access").length;
const doneCount = games.filter((g) => g.status === "done").length;
const inProgressCount = games.filter((g) => g.status === "in-progress" || g.status === "early-access" || g.status === "fundraising").length;

const featuredItems = [
  {
    type: "news" as const,
    title: "Сайт повністю оновлено",
    description: "Новий світлий інтерфейс у стилі white liquid glass — легкий, прозорий, швидкий. Освіжені картки, плавні анімації, краща мобільна версія.",
    image: "/images/site-redesign-2026.svg",
    badge: "НОВИНА",
    label: "Свіжий редизайн",
    date: "28 квітня 2026",
    noOverlay: true,
  },
];

// Усі активні збори: і повністю-fundraising проєкти, і ті, де гра вже доступна,
// але ведеться збір на подальші роботи (наприклад, MGS Δ).
const fundraisingGames = games.filter(
  (g) => !!g.fundraisingGoal && !g.fundraisingCompleted
);

const RING_R = 34;
const RING_C = 2 * Math.PI * RING_R;
const ringOffset = RING_C * (1 - overall / 100);
---

<section class="relative pt-28 pb-12 sm:pt-32 sm:pb-16">

  <!-- Static decorative gradient layer with soft bottom fade so colours don't cut off abruptly -->
  <div class="absolute inset-0 -z-10 pointer-events-none" aria-hidden="true"
       style="background:
         radial-gradient(420px 360px at 12% 18%, rgba(99,102,241,0.28), transparent 65%),
         radial-gradient(380px 340px at 92% 22%, rgba(56,189,248,0.26), transparent 65%),
         radial-gradient(520px 420px at 50% 105%, rgba(167,139,250,0.22), transparent 65%);
         -webkit-mask-image: linear-gradient(180deg, #000 0%, #000 78%, transparent 100%);
                 mask-image: linear-gradient(180deg, #000 0%, #000 78%, transparent 100%);"></div>

  <div class="relative z-10 mx-auto max-w-6xl w-full px-4 sm:px-6 lg:px-8">

    <!-- ═══ Top: Title + supporting cards ═══ -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 lg:gap-5 items-stretch">

      <!-- Brand block -->
      <div class="lb-glass-strong lg:col-span-7 p-6 sm:p-8 flex flex-col justify-center hero-card hero-delay-1">
        <h1 class="text-[2rem] sm:text-5xl lg:text-[3.25rem] font-black tracking-tight leading-[1.05] mb-4 text-slate-900">
          Перекладаємо те, у&nbsp;що
          <span class="lb-gradient-text whitespace-nowrap">самі граємо</span>
        </h1>
        <p class="hero-subtitle text-base sm:text-lg leading-relaxed max-w-xl text-slate-600">
          <span class="hero-word">Сюжет,</span>
          <span class="hero-word">інтерфейс</span>
          <span class="hero-word">і дрібниці</span>
          <span class="hero-word">—</span>
          <span class="hero-word">українською.</span>
        </p>
      </div>

      <!-- Featured carousel -->
      <div
        id="featured-carousel"
        class="lb-glass lg:col-span-5 relative min-h-[240px] overflow-hidden hero-card hero-delay-2 group"
      >
        {featuredItems.map((item, index) => (
          <div
            class={`featured-slide absolute inset-0 transition-opacity duration-700 ${index === 0 ? "opacity-100 z-10" : "opacity-0 z-0"}`}
            data-slide={index}
          >
            <img
              src={item.image}
              alt={item.title}
              class="absolute inset-0 w-full h-full object-cover"
              loading={index === 0 ? "eager" : "lazy"}
            />
            {!item.noOverlay && (
              <div class="absolute inset-0 bg-gradient-to-t from-slate-900/85 via-slate-900/55 to-slate-900/10"></div>
            )}
            {item.noOverlay && (
              <>
                <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-slate-900/30 to-transparent"></div>
                <div
                  class="absolute bottom-0 left-0 right-0 h-3/5 pointer-events-none"
                  style="backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); -webkit-mask-image: linear-gradient(0deg, rgba(0,0,0,1) 0%, rgba(0,0,0,0.85) 45%, transparent 100%); mask-image: linear-gradient(0deg, rgba(0,0,0,1) 0%, rgba(0,0,0,0.85) 45%, transparent 100%);"
                ></div>
              </>
            )}

            <div class="relative h-full flex flex-col justify-between p-6 sm:p-7">
              <div class="flex items-start justify-between gap-3">
                <span class="inline-flex items-center px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider rounded-lg bg-white/95 text-indigo-600 border border-white/60 shadow-sm">
                  {item.badge}
                </span>
                <span class="text-[10px] font-semibold uppercase tracking-wider text-white/95 px-2.5 py-1 rounded-lg bg-slate-900/35 border border-white/25 shadow-sm">
                  {item.date}
                </span>
              </div>
              <div>
                <span class="text-[10px] font-bold uppercase tracking-[0.18em] text-amber-300 mb-1.5 block">
                  {item.label}
                </span>
                <h3 class="text-white font-bold text-xl sm:text-2xl leading-tight mb-2 drop-shadow-sm">
                  {item.title}
                </h3>
                <p class="text-white/80 text-sm leading-relaxed max-w-md line-clamp-2">
                  {item.description}
                </p>
              </div>
            </div>
          </div>
        ))}

        {featuredItems.length > 1 && (
          <>
            <button
              id="carousel-prev"
              class="hidden md:flex absolute left-3 top-1/2 -translate-y-1/2 z-20 w-9 h-9 rounded-full bg-white/95 border border-white/70 text-slate-700 hover:bg-white shadow-md items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"
              aria-label="Попередній">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
              </svg>
            </button>
            <button
              id="carousel-next"
              class="hidden md:flex absolute right-3 top-1/2 -translate-y-1/2 z-20 w-9 h-9 rounded-full bg-white/95 border border-white/70 text-slate-700 hover:bg-white shadow-md items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity"
              aria-label="Наступний">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </button>
            <div class="absolute bottom-3.5 left-1/2 -translate-x-1/2 z-20 flex gap-1.5">
              {featuredItems.map((_, index) => (
                <button
                  class={`carousel-dot h-1.5 rounded-full transition-all duration-300 ${index === 0 ? "bg-white w-6" : "bg-white/55 w-1.5 hover:bg-white/80"}`}
                  data-dot={index}
                  aria-label={`Слайд ${index + 1}`}
                ></button>
              ))}
            </div>
          </>
        )}
      </div>
    </div>

    <!-- ═══ Bottom: Metric cards ═══ -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 sm:gap-4 mt-4 sm:mt-5">

      <!-- Overall progress ring -->
      <div class="lb-glass p-5 flex flex-col items-center justify-center text-center min-h-[150px] hero-card hero-delay-3">
        <div class="relative w-[88px] h-[88px] mb-2">
          <svg class="w-full h-full -rotate-90" viewBox="0 0 80 80">
            <defs>
              <linearGradient id="heroRingG" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#6366f1" />
                <stop offset="100%" stop-color="#0ea5e9" />
              </linearGradient>
            </defs>
            <circle cx="40" cy="40" r={RING_R} fill="none" stroke="rgba(15,23,42,0.08)" stroke-width="6" />
            <circle cx="40" cy="40" r={RING_R} fill="none" stroke="url(#heroRingG)" stroke-width="6"
                    stroke-linecap="round" stroke-dasharray={RING_C} stroke-dashoffset={RING_C}
                    class="ring-progress" style={`--ring-target: ${ringOffset}`} />
          </svg>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="text-xl font-black text-slate-900 tabular-nums ring-counter" data-target={overall}>0%</span>
          </div>
        </div>
        <span class="text-[10px] font-bold tracking-[0.16em] uppercase text-slate-500">Загальний прогрес</span>
      </div>

      <!-- Project counts -->
      <div class="lb-glass p-5 flex flex-col items-center justify-center text-center min-h-[150px] hero-card hero-delay-4">
        <span class="block text-3xl font-black tabular-nums lb-gradient-text">{totalGames}</span>
        <span class="text-[10px] font-bold tracking-[0.16em] uppercase text-slate-500 mt-1">Усього проєктів</span>
        <div class="grid grid-cols-2 gap-2 mt-3 w-full text-[11px]">
          <div class="text-center">
            <span class="block font-bold text-emerald-600 tabular-nums">{doneCount + earlyAccessCount}</span>
            <span class="text-slate-500">доступно</span>
          </div>
          <div class="text-center">
            <span class="block font-bold text-indigo-600 tabular-nums">{inProgressCount}</span>
            <span class="text-slate-500">у роботі</span>
          </div>
        </div>
      </div>

      <!-- Fundraising — компактний список з прогрес-барами та сумами -->
      <div class="lb-glass p-4 sm:p-5 flex flex-col min-h-[150px] hero-card hero-delay-5 col-span-2">
        {(() => {
          const fmt = (n: number) => n.toLocaleString("uk-UA");
          return (
            <>
              <div class="mb-3">
                <span class="text-[10px] font-bold tracking-[0.16em] uppercase text-amber-700">Збір коштів</span>
              </div>
              <div class="space-y-3">
                {fundraisingGames.map((game) => {
                  const raised = game.fundraisingRaised ?? 0;
                  const goal = game.fundraisingGoal ?? 0;
                  const pct = goal > 0 ? Math.min(100, Math.round((raised / goal) * 100)) : 0;
                  return (
                    <button
                      type="button"
                      data-game-detail={game.id}
                      class="group w-full flex items-center gap-2.5 text-left hover:bg-amber-50/60 rounded-lg px-1.5 py-1 -mx-1.5 transition-colors"
                      aria-label={`Збір на ${game.title}`}
                    >
                      <span class="relative w-8 h-11 rounded-md overflow-hidden border border-white/80 shadow-[0_6px_14px_-8px_rgba(15,23,42,0.5)] shrink-0">
                        <img src={game.cover} alt={game.title} class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
                      </span>
                      <span class="flex-1 min-w-0">
                        <span class="flex items-center justify-between gap-2 mb-1">
                          <span class="text-[11px] font-bold text-slate-800 truncate group-hover:text-amber-700 transition-colors">{game.title}</span>
                          <span class="text-[10px] font-bold text-amber-700 tabular-nums shrink-0">{pct}%</span>
                        </span>
                        <span class="block h-1.5 rounded-full bg-amber-100 overflow-hidden">
                          <span class="block h-full rounded-full bg-gradient-to-r from-amber-400 to-orange-400" style={`width: ${pct}%`}></span>
                        </span>
                        <span class="block text-[10px] text-slate-500 font-medium tabular-nums mt-1">
                          <span class="text-amber-700 font-bold">{fmt(raised)}</span> з {fmt(goal)} ₴
                        </span>
                      </span>
                    </button>
                  );
                })}
              </div>
            </>
          );
        })()}
      </div>

    </div>

  </div>
</section>

<style>
  .hero-card {
    opacity: 0;
    transform: translateY(20px) scale(0.98);
    animation: heroCardIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .hero-delay-1 { animation-delay: 0.05s; }
  .hero-delay-2 { animation-delay: 0.15s; }
  .hero-delay-3 { animation-delay: 0.25s; }
  .hero-delay-4 { animation-delay: 0.30s; }
  .hero-delay-5 { animation-delay: 0.35s; }
  .hero-delay-6 { animation-delay: 0.40s; }

  @keyframes heroCardIn {
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .hero-word {
    display: inline-block;
    opacity: 0;
    transform: translateY(8px);
    animation: heroWord 0.55s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .hero-word:nth-child(1) { animation-delay: 0.4s; }
  .hero-word:nth-child(2) { animation-delay: 0.55s; }
  .hero-word:nth-child(3) { animation-delay: 0.7s; }
  .hero-word:nth-child(4) { animation-delay: 0.85s; }
  .hero-word:nth-child(5) { animation-delay: 1.0s; }
  @keyframes heroWord { to { opacity: 1; transform: translateY(0); } }

  .ring-progress {
    transition: stroke-dashoffset 1.4s cubic-bezier(0.16, 1, 0.3, 1);
    animation: ringDraw 1.4s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
  }
  @keyframes ringDraw { to { stroke-dashoffset: var(--ring-target); } }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-card, .hero-word, .ring-progress { animation: none; opacity: 1; transform: none; }
  }
</style>

<script>
  // Hero ring counter
  const heroCounter = document.querySelector(".ring-counter") as HTMLSpanElement | null;
  if (heroCounter) {
    const target = parseInt(heroCounter.dataset.target || "0", 10);
    const duration = 1400;
    const start = performance.now();
    const tick = (now: number) => {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      heroCounter.textContent = `${Math.round(eased * target)}%`;
      if (progress < 1) requestAnimationFrame(tick);
    };
    setTimeout(() => requestAnimationFrame(tick), 300);
  }

  // Carousel
  const slides = document.querySelectorAll<HTMLDivElement>(".featured-slide");
  const dots = document.querySelectorAll<HTMLButtonElement>(".carousel-dot");
  const prevBtn = document.getElementById("carousel-prev");
  const nextBtn = document.getElementById("carousel-next");
  let currentSlide = 0;

  const goToSlide = (index: number) => {
    slides.forEach((slide, i) => {
      slide.classList.toggle("opacity-100", i === index);
      slide.classList.toggle("z-10", i === index);
      slide.classList.toggle("opacity-0", i !== index);
      slide.classList.toggle("z-0", i !== index);
    });
    dots.forEach((dot, i) => {
      const active = i === index;
      dot.classList.toggle("bg-white", active);
      dot.classList.toggle("w-6", active);
      dot.classList.toggle("bg-white/55", !active);
      dot.classList.toggle("w-1.5", !active);
    });
    currentSlide = index;
  };

  prevBtn?.addEventListener("click", () => goToSlide(currentSlide === 0 ? slides.length - 1 : currentSlide - 1));
  nextBtn?.addEventListener("click", () => goToSlide(currentSlide === slides.length - 1 ? 0 : currentSlide + 1));
  dots.forEach((dot, index) => dot.addEventListener("click", () => goToSlide(index)));

  const isMobile = window.innerWidth < 768;
  const interval = isMobile ? 4000 : 6000;
  let auto = setInterval(() => goToSlide(currentSlide === slides.length - 1 ? 0 : currentSlide + 1), interval);

  const carousel = document.getElementById("featured-carousel");
  if (!isMobile && carousel) {
    carousel.addEventListener("mouseenter", () => clearInterval(auto));
    carousel.addEventListener("mouseleave", () => {
      auto = setInterval(() => goToSlide(currentSlide === slides.length - 1 ? 0 : currentSlide + 1), interval);
    });
  }
</script>
