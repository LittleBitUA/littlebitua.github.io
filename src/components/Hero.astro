---
// ─── Hero: Bento Grid ─────────────────────────────────────────
// Data-rich dashboard-style hero with glassmorphism cards.

import { getOverallProgress, games, STATUS_LABELS } from "../data/games";

const overall = getOverallProgress();
const totalGames = games.length;
const doneGames = games.filter((g) => g.status === "early-access").length;
const activeGames = games.filter(
  (g) => g.progress > 0 && g.progress < 100
).length;

// Featured carousel items (games + news)
const featuredItems = [
  {
    type: 'news' as const,
    title: 'Завершено збір коштів на Yakuza: Like a Dragon',
    description: 'Успішно завершено збір коштів на текстову локалізацію Yakuza: Like a Dragon. Дякуємо всім за підтримку! Продовжуємо роботу над перекладом.',
    image: 'https://cdn2.steamgriddb.com/hero/7377f47f95a1202ea8d330061b674dea.png',
    badge: 'НОВИНА',
    label: 'Збір завершено!',
    date: '17 лютого 2026'
  },
  {
    type: 'news' as const,
    title: 'Вийшли усі 8 епізодів Dispatch',
    description: 'Повний переклад усіх 8 епізодів Dispatch вже доступний для завантаження. Насолоджуйтесь повною історією українською!',
    image: '/images/dispatch-hero.png',
    badge: 'НОВИНА',
    label: 'Усі епізоди вже доступні!',
    date: '4 березня 2026'
  },
  {
    type: 'news' as const,
    title: 'Демоверсія Yakuza Kiwami 3 & Dark Ties',
    description: 'Демоверсія Yakuza Kiwami 3 & Dark Ties вийде у березні 2026 року. Підготуйтесь до ремейку третьої частини серії!',
    image: 'https://cdn2.steamgriddb.com/grid/d7fbe5fb946867aacf79463f8f36981c.png',
    badge: 'НОВИНА',
    label: 'Демо вже скоро!',
    date: 'березень 2026'
  },
  {
    type: 'news' as const,
    title: 'Yakuza Kiwami 2',
    description: 'Повний текстовий переклад гри українською та українізовані текстури. Усе — від сюжету й побічних активностей до інтерфейсу, підказок.',
    image: 'https://cdn2.steamgriddb.com/hero/8a9ab2a87298a2fed1c31aebff294cf9.png',
    badge: 'НАЙБЛИЖЧИЙ РЕЛІЗ',
    label: 'У процесі редагування. Слідкуйте за оновленнями!',
    date: '96% готовності'
  }
];

const fundraisingGames = games.filter((g) => g.status === "fundraising");

const RING_R = 34;
const RING_C = 2 * Math.PI * RING_R; // ~213.63
const ringOffset = RING_C * (1 - overall / 100);
---

<section class="relative min-h-[100vh] flex items-center overflow-hidden">

  <!-- ═══ Background ═══ -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-surface-900" />
    <!-- Gradient orbs (animated) -->
    <div class="orb orb-1 absolute top-[10%] left-[15%] w-[800px] h-[600px] rounded-full
                bg-[radial-gradient(ellipse,#6d5dfc_0%,transparent_70%)] will-change-transform" />
    <div class="orb orb-2 absolute bottom-[5%] right-[10%] w-[600px] h-[500px] rounded-full
                bg-[radial-gradient(ellipse,#1b9aaa_0%,transparent_70%)] will-change-transform" />
    <div class="orb orb-3 absolute top-[45%] left-[50%] w-[500px] h-[400px] rounded-full
                bg-[radial-gradient(ellipse,#9d4edd_0%,transparent_70%)] will-change-transform" />
    <!-- Grid pattern -->
    <div class="absolute inset-0 opacity-[0.025]"
         style="background-image: linear-gradient(rgba(255,255,255,.07) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.07) 1px, transparent 1px); background-size: 64px 64px;" />
    <!-- Noise -->
    <div class="absolute inset-0 opacity-[0.03]"
         style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22 opacity=%221%22/%3E%3C/svg%3E')" />
  </div>

  <!-- ═══ Bento Grid ═══ -->
  <div class="relative z-10 mx-auto max-w-6xl w-full px-4 sm:px-6 lg:px-8 py-28 sm:py-32">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">

      <!-- ──── 1. Brand Card (large) ──── -->
      <div class="col-span-2 relative overflow-hidden rounded-2xl
                  bg-white/[0.03] border border-white/[0.06]
                  bento-item bento-delay-1">
        <!-- Top accent line -->
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent/50 to-transparent" />
        <div class="flex flex-col justify-between h-full p-7 sm:p-8 lg:p-10 min-h-[280px] lg:min-h-[320px]">
          <div>
            <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-6 rounded-full
                        bg-accent/10 border border-accent/20">
              <span class="relative flex h-1.5 w-1.5">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
                <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-accent"></span>
              </span>
              <span class="text-[11px] font-semibold text-accent-light tracking-wide uppercase">
                {totalGames} проєктів у роботі
              </span>
            </div>
            <h1 class="text-3xl sm:text-4xl lg:text-[2.75rem] font-black tracking-tight text-white leading-[1.1] mb-3">
              Перекладаємо те, у&nbsp;що самі граємо&nbsp;🎮
            </h1>
            <p class="hero-subtitle text-surface-200 text-sm sm:text-base leading-relaxed max-w-sm">
              <span class="hero-word">Сюжет,</span>
              <span class="hero-word">інтерфейс</span>
              <span class="hero-word">і дрібниці</span>
              <span class="hero-word">—</span>
              <span class="hero-word">українською.</span>
            </p>
          </div>
        </div>
      </div>

      <!-- ──── 2. Featured Carousel Card ──── -->
      <div class="col-span-2 relative overflow-hidden rounded-2xl
                  border border-white/[0.06] group
                  min-h-[240px] lg:min-h-[320px]
                  bento-item bento-delay-2" id="featured-carousel">

        {featuredItems.map((item, index) => (
          <div
            class={`featured-slide absolute inset-0 transition-all duration-500 ${index === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0'}`}
            data-slide={index}>
            <img
              src={item.type === 'game' ? item.game.cover : item.image}
              alt={item.type === 'game' ? item.game.title : item.title}
              class="absolute inset-0 w-full h-full object-cover
                     transition-transform duration-700 group-hover:scale-102"
              loading={index === 0 ? 'eager' : 'lazy'} />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/50 to-black/30" />
            <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/20 to-transparent" />

            <div class="relative h-full flex flex-col justify-between p-6 min-h-[240px] lg:min-h-[320px]">
              <div class="flex items-start justify-between gap-3">
                <span class="inline-flex items-center px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider
                             rounded-lg bg-black/50 backdrop-blur-md
                             {item.type === 'game' ? 'text-steam-blue border border-steam-blue/30' : 'text-yellow-400 border border-yellow-400/30'}">
                  {item.type === 'game' ? STATUS_LABELS[item.game.status] : item.badge}
                </span>
                <span class="text-[10px] text-white/70 font-medium uppercase tracking-wider backdrop-blur-md
                             px-2 py-1 rounded-lg bg-black/50">
                  {item.type === 'game' ? item.badge : item.date}
                </span>
              </div>

              <div>
                <span class="text-[10px] text-yellow-400/80 font-semibold uppercase tracking-wider mb-1 block">
                  {item.label}
                </span>
                <h3 class="text-white font-bold text-xl sm:text-2xl leading-tight mb-1.5">
                  {item.type === 'game' ? item.game.title : item.title}
                </h3>
                <p class="text-white/60 text-sm leading-relaxed mb-4 max-w-md line-clamp-2">
                  {item.type === 'game' ? item.game.description : item.description}
                </p>

                {item.type === 'game' && (
                  <div class="flex items-center gap-3 max-w-sm">
                    <div class="flex-1 h-2 rounded-full bg-white/15 overflow-hidden">
                      <div class="h-full rounded-full bg-gradient-to-r from-accent to-steam-blue featured-progress"
                           data-progress={item.game.progress}
                           style={`width: 0%`} />
                    </div>
                    <span class="text-sm font-bold text-white tabular-nums min-w-[3ch] text-right">
                      {item.game.progress}%
                    </span>
                  </div>
                )}
              </div>
            </div>
          </div>
        ))}

        <!-- Navigation arrows (desktop only) -->
        <button
          id="carousel-prev"
          class="hidden md:flex absolute left-4 top-1/2 -translate-y-1/2 z-20
                 w-10 h-10 rounded-full bg-black/60 backdrop-blur-md border border-white/20
                 items-center justify-center
                 text-white hover:bg-black/80 hover:border-white/30
                 transition-all duration-200 opacity-0 group-hover:opacity-100
                 focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-accent/50"
          aria-label="Попередній">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button
          id="carousel-next"
          class="hidden md:flex absolute right-4 top-1/2 -translate-y-1/2 z-20
                 w-10 h-10 rounded-full bg-black/60 backdrop-blur-md border border-white/20
                 items-center justify-center
                 text-white hover:bg-black/80 hover:border-white/30
                 transition-all duration-200 opacity-0 group-hover:opacity-100
                 focus:opacity-100 focus:outline-none focus:ring-2 focus:ring-accent/50"
          aria-label="Наступний">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>

        <!-- Progress bar (mobile only) -->
        <div class="md:hidden absolute bottom-0 left-0 right-0 h-1 bg-white/10 z-20">
          <div id="carousel-progress" class="h-full bg-white/60 transition-none" style="width: 0%"></div>
        </div>

        <!-- Indicators -->
        <div class="absolute bottom-4 left-1/2 -translate-x-1/2 z-20 flex gap-1.5">
          {featuredItems.map((_, index) => (
            <button
              class={`carousel-dot w-2 h-2 rounded-full transition-all duration-300 ${index === 0 ? 'bg-white w-6' : 'bg-white/40 hover:bg-white/60'}`}
              data-dot={index}
              aria-label={`Слайд ${index + 1}`} />
          ))}
        </div>
      </div>

      <!-- ──── 3. Overall Progress Card ──── -->
      <div class="relative overflow-hidden rounded-2xl
                  bg-white/[0.03] border border-white/[0.06]
                  flex flex-col items-center justify-center p-6 min-h-[160px]
                  bento-item bento-delay-3">
        <div class="relative w-[88px] h-[88px] mb-2">
          <svg class="w-full h-full -rotate-90" viewBox="0 0 80 80">
            <defs>
              <linearGradient id="heroRingGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#6d5dfc" />
                <stop offset="100%" stop-color="#1b9aaa" />
              </linearGradient>
              <filter id="ringGlow">
                <feGaussianBlur stdDeviation="2.5" result="blur" />
                <feMerge>
                  <feMergeNode in="blur" />
                  <feMergeNode in="SourceGraphic" />
                </feMerge>
              </filter>
            </defs>
            <circle cx="40" cy="40" r={RING_R} fill="none"
                    stroke="rgba(255,255,255,0.05)" stroke-width="5" />
            <circle cx="40" cy="40" r={RING_R} fill="none"
                    stroke="url(#heroRingGrad)" stroke-width="5.5"
                    stroke-linecap="round"
                    stroke-dasharray={RING_C}
                    stroke-dashoffset={RING_C}
                    filter="url(#ringGlow)"
                    class="ring-progress"
                    style={`--ring-target: ${ringOffset}`} />
          </svg>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="text-2xl font-black text-white tabular-nums ring-counter" data-target={overall}>0%</span>
          </div>
        </div>
        <span class="text-[11px] text-surface-300 font-medium uppercase tracking-wider">
          Загальний прогрес
        </span>
      </div>

      <!-- ──── 4. Stats Card ──── -->
      <div class="relative overflow-hidden rounded-2xl
                  bg-white/[0.03] border border-white/[0.06]
                  flex items-center justify-center p-6 min-h-[160px]
                  bento-item bento-delay-4">
        <div class="grid grid-cols-2 gap-4 text-center w-full">
          <div>
            <span class="block text-3xl sm:text-4xl font-black text-white tabular-nums">
              {totalGames}
            </span>
            <span class="text-[11px] text-surface-300 font-medium uppercase tracking-wider">
              Проєктів
            </span>
          </div>
          <div class="border-l border-white/[0.06] pl-4">
            <span class="block text-3xl sm:text-4xl font-black text-steam-green tabular-nums">
              {doneGames}
            </span>
            <span class="text-[11px] text-surface-300 font-medium uppercase tracking-wider">
              У ранньому доступі
            </span>
          </div>
        </div>
      </div>

      <!-- ──── 5. Completed Games Gallery ──── -->
      <div class="relative overflow-hidden rounded-2xl
                  bg-white/[0.03] border border-white/[0.06]
                  p-5 min-h-[160px]
                  bento-item bento-delay-5">
        <span class="text-[11px] text-surface-300 font-medium uppercase tracking-wider mb-3 block">
          Збір коштів
        </span>
        <div class="flex gap-2.5 mt-1" id="fundraising-thumbs">
          {fundraisingGames.map((game) => (
            <button
              class="relative flex-1 aspect-[3/4] max-w-[80px] rounded-xl overflow-hidden
                     border border-white/10 cursor-pointer transition-transform duration-200 hover:scale-105
                     focus:outline-none focus:ring-2 focus:ring-orange-400/50"
              data-fr-title={`Збір на локалізацію ${game.title}`}
              data-fr-raised={game.fundraisingRaised ?? 0}
              data-fr-goal={game.fundraisingGoal ?? 0}
              title={game.title}>
              <img src={game.cover} alt={game.title}
                   class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-orange-400/30 to-transparent" />
              <div class="absolute bottom-1 right-1">
                <svg class="w-3.5 h-3.5 text-orange-400 drop-shadow-lg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round"
                    d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                </svg>
              </div>
            </button>
          ))}
        </div>
        <!-- Fundraising info popup -->
        <div id="fr-popup" class="hidden mt-2 p-3 sm:p-3 rounded-xl bg-black/70 backdrop-blur-md border border-orange-400/20">
          <p id="fr-title" class="text-white font-semibold mb-2 leading-snug text-xs"></p>
          <div class="flex flex-col sm:flex-row sm:items-center gap-1.5 sm:gap-2">
            <div class="flex-1 h-2 sm:h-1.5 rounded-full bg-white/10 overflow-hidden">
              <div id="fr-bar" class="h-full rounded-full bg-gradient-to-r from-orange-400 to-orange-300 transition-all duration-500" style="width: 0%" />
            </div>
            <span id="fr-amount" class="text-xs text-orange-400 font-bold tabular-nums shrink-0"></span>
          </div>
        </div>
      </div>

      <!-- ──── 6. CTA Donate Card ──── -->
      <a href="https://donatello.to/LittleBitUA"
         target="_blank" rel="noopener noreferrer"
         class="relative overflow-hidden rounded-2xl
                bg-accent/[0.06] border border-accent/20
                flex flex-col items-center justify-center p-6 min-h-[160px]
                group transition-all duration-300 hover:bg-accent/[0.12] hover:border-accent/30
                hover:shadow-lg hover:shadow-accent/10
                bento-item bento-delay-6">
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent/30 to-transparent" />
        <div class="w-11 h-11 rounded-xl bg-accent/15 border border-accent/25
                    flex items-center justify-center mb-3
                    group-hover:scale-110 transition-transform duration-300">
          <svg class="w-5 h-5 text-accent-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
          </svg>
        </div>
        <span class="text-sm font-bold text-accent-light group-hover:text-white transition-colors text-center">
          Підтримати<br class="sm:hidden" /> збір
        </span>
        <span class="text-[10px] text-surface-300 mt-1 text-center">Donatello</span>
      </a>

    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 right-0 h-28 bg-gradient-to-t from-surface-900 to-transparent z-20 pointer-events-none" />

  <!-- Projects CTA -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-30">
    <a href="#projects"
       class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full
              bg-white/[0.04] backdrop-blur-md border border-white/10
              hover:bg-white/[0.08] hover:border-white/20
              transition-all duration-300 group">
      <span class="text-xs font-bold uppercase tracking-wider text-white/90 group-hover:text-white">
        Проєкти
      </span>
      <svg class="w-4 h-4 text-white/70 group-hover:text-white transition-all duration-300 group-hover:translate-y-0.5"
           fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </a>
  </div>
</section>

<style>

  /* ── Subtitle word reveal ── */
  .hero-word {
    display: inline-block;
    opacity: 0;
    transform: translateY(8px);
    animation: wordReveal 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero-word:nth-child(1) { animation-delay: 0.4s; }
  .hero-word:nth-child(2) { animation-delay: 0.55s; }
  .hero-word:nth-child(3) { animation-delay: 0.7s; }
  .hero-word:nth-child(4) { animation-delay: 0.85s; }
  .hero-word:nth-child(5) { animation-delay: 1.0s; }

  @keyframes wordReveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-word { animation: none; opacity: 1; transform: none; }
  }

  /* ── Background orb drift ── */
  .orb {
    opacity: 0.08;
  }

  /* Disable orb animations on mobile for performance */
  @media (min-width: 768px) {
    .orb-1 {
      animation: drift1 18s ease-in-out infinite alternate;
    }
    .orb-2 {
      animation: drift2 22s ease-in-out infinite alternate;
    }
    .orb-3 {
      animation: drift3 20s ease-in-out infinite alternate;
    }
  }

  @keyframes drift1 {
    0%   { transform: translate(0, 0) scale(1); opacity: 0.06; }
    50%  { transform: translate(80px, -60px) scale(1.15); opacity: 0.12; }
    100% { transform: translate(-60px, 40px) scale(0.9); opacity: 0.07; }
  }
  @keyframes drift2 {
    0%   { transform: translate(0, 0) scale(1); opacity: 0.05; }
    50%  { transform: translate(-70px, 50px) scale(1.2); opacity: 0.11; }
    100% { transform: translate(50px, -30px) scale(0.85); opacity: 0.06; }
  }
  @keyframes drift3 {
    0%   { transform: translate(0, 0) scale(1); opacity: 0.04; }
    50%  { transform: translate(60px, 40px) scale(1.18); opacity: 0.10; }
    100% { transform: translate(-40px, -50px) scale(0.92); opacity: 0.05; }
  }

  @media (prefers-reduced-motion: reduce) {
    .orb { animation: none; }
  }

  /* ── Card entrance animation ── */
  .bento-item {
    opacity: 0;
    transform: translateY(18px) scale(0.97);
    animation: bentoIn 0.65s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .bento-delay-1 { animation-delay: 0.05s; }
  .bento-delay-2 { animation-delay: 0.15s; }
  .bento-delay-3 { animation-delay: 0.25s; }
  .bento-delay-4 { animation-delay: 0.3s; }
  .bento-delay-5 { animation-delay: 0.35s; }
  .bento-delay-6 { animation-delay: 0.4s; }

  @keyframes bentoIn {
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* ── Progress ring draw animation ── */
  .ring-progress {
    animation: ringDraw 1.4s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards;
  }

  @keyframes ringDraw {
    to {
      stroke-dashoffset: var(--ring-target);
    }
  }

  /* ── Featured game progress bar transition + glow animation ── */
  .featured-progress {
    transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
  }

  /* Enable glow animation only on desktop for performance */
  @media (min-width: 768px) {
    .featured-progress {
      animation: progressGlow 2s ease-in-out infinite;
    }
  }

  @keyframes progressGlow {
    0%, 100% {
      filter: brightness(1) drop-shadow(0 0 0px rgba(109, 93, 252, 0));
    }
    50% {
      filter: brightness(1.15) drop-shadow(0 0 8px rgba(109, 93, 252, 0.6));
    }
  }

  /* ── Fade in animation ── */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fadeIn {
    animation: fadeIn 0.6s ease-out;
  }

  /* ── Subtle card hover glow ── */
  .bento-item {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  /* Disable hover effects on mobile/touch devices for performance */
  @media (hover: hover) and (pointer: fine) {
    .bento-item:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    }
  }

  /* line clamp fallback */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  // Hero ring counter animation
  const heroCounter = document.querySelector(".ring-counter") as HTMLSpanElement | null;
  if (heroCounter) {
    const target = parseInt(heroCounter.dataset.target || "0", 10);
    const duration = 1400;
    const start = performance.now();
    const tick = (now: number) => {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      heroCounter.textContent = `${Math.round(eased * target)}%`;
      if (progress < 1) requestAnimationFrame(tick);
    };
    // Delay to sync with ring draw animation (0.5s delay)
    setTimeout(() => requestAnimationFrame(tick), 500);
  }

  // Fundraising thumbnail popups
  const popup = document.getElementById("fr-popup");
  const frTitle = document.getElementById("fr-title");
  const frBar = document.getElementById("fr-bar");
  const frAmount = document.getElementById("fr-amount");
  const thumbs = document.querySelectorAll<HTMLButtonElement>("#fundraising-thumbs button");
  let activeThumb: HTMLButtonElement | null = null;

  const fmt = (n: number) => n.toLocaleString("uk-UA");

  thumbs.forEach((btn) => {
    btn.addEventListener("click", () => {
      if (!popup || !frTitle || !frBar || !frAmount) return;
      if (activeThumb === btn) {
        popup.classList.add("hidden");
        activeThumb = null;
        return;
      }
      activeThumb = btn;
      const title = btn.dataset.frTitle || "";
      const raised = parseInt(btn.dataset.frRaised || "0", 10);
      const goal = parseInt(btn.dataset.frGoal || "0", 10);
      const pct = goal > 0 ? Math.min(100, Math.round((raised / goal) * 100)) : 0;

      frTitle.innerHTML = title.replace("Збір на локалізацію ", "Збір на локалізацію<br>");
      frAmount.textContent = `${fmt(raised)}₴ із ${fmt(goal)}₴`;
      frBar.style.width = `${pct}%`;
      popup.classList.remove("hidden");
    });
  });

  // Featured carousel
  const slides = document.querySelectorAll<HTMLDivElement>(".featured-slide");
  const dots = document.querySelectorAll<HTMLButtonElement>(".carousel-dot");
  const prevBtn = document.getElementById("carousel-prev");
  const nextBtn = document.getElementById("carousel-next");
  const progressBar = document.getElementById("carousel-progress");
  let currentSlide = 0;
  let progressAnimation: Animation | null = null;

  const goToSlide = (index: number) => {
    slides.forEach((slide, i) => {
      if (i === index) {
        slide.classList.add("opacity-100", "z-10");
        slide.classList.remove("opacity-0", "z-0");
        // Animate progress bar if it's a game slide
        const gameProgressBar = slide.querySelector<HTMLDivElement>(".featured-progress");
        if (gameProgressBar) {
          const progress = gameProgressBar.dataset.progress || "0";
          setTimeout(() => {
            gameProgressBar.style.width = `${progress}%`;
          }, 100);
        }
      } else {
        slide.classList.remove("opacity-100", "z-10");
        slide.classList.add("opacity-0", "z-0");
      }
    });

    dots.forEach((dot, i) => {
      if (i === index) {
        dot.classList.add("bg-white", "w-6");
        dot.classList.remove("bg-white/40");
      } else {
        dot.classList.remove("bg-white", "w-6");
        dot.classList.add("bg-white/40");
      }
    });

    currentSlide = index;

    // Restart progress bar animation on mobile
    if (progressBar && isMobile) {
      // Cancel previous animation
      if (progressAnimation) {
        progressAnimation.cancel();
      }
      // Reset progress
      progressBar.style.width = "0%";
      // Start new animation
      progressAnimation = progressBar.animate(
        [{ width: "0%" }, { width: "100%" }],
        { duration: rotateInterval, easing: "linear", fill: "forwards" }
      );
    }
  };

  prevBtn?.addEventListener("click", () => {
    const newIndex = currentSlide === 0 ? slides.length - 1 : currentSlide - 1;
    goToSlide(newIndex);
  });

  nextBtn?.addEventListener("click", () => {
    const newIndex = currentSlide === slides.length - 1 ? 0 : currentSlide + 1;
    goToSlide(newIndex);
  });

  dots.forEach((dot, index) => {
    dot.addEventListener("click", () => goToSlide(index));
  });

  // Auto-rotate - 3s on mobile with progress bar
  const isMobile = window.innerWidth < 768;
  const rotateInterval = isMobile ? 3000 : 5000; // 3s on mobile, 5s on desktop

  let autoRotate = setInterval(() => {
    const newIndex = currentSlide === slides.length - 1 ? 0 : currentSlide + 1;
    goToSlide(newIndex);
  }, rotateInterval);

  // Pause auto-rotate on hover (desktop only)
  const carousel = document.getElementById("featured-carousel");
  if (!isMobile) {
    carousel?.addEventListener("mouseenter", () => clearInterval(autoRotate), { passive: true });
    carousel?.addEventListener("mouseleave", () => {
      autoRotate = setInterval(() => {
        const newIndex = currentSlide === slides.length - 1 ? 0 : currentSlide + 1;
        goToSlide(newIndex);
      }, rotateInterval);
    }, { passive: true });
  }

  // Initialize first slide progress bar
  setTimeout(() => {
    const firstSlide = slides[0];
    const gameProgressBar = firstSlide?.querySelector<HTMLDivElement>(".featured-progress");
    if (gameProgressBar) {
      const progress = gameProgressBar.dataset.progress || "0";
      gameProgressBar.style.width = `${progress}%`;
    }

    // Start carousel progress bar animation on mobile
    if (progressBar && isMobile) {
      progressAnimation = progressBar.animate(
        [{ width: "0%" }, { width: "100%" }],
        { duration: rotateInterval, easing: "linear", fill: "forwards" }
      );
    }
  }, 600);
</script>
