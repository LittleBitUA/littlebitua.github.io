---
// ─── Timeline Component ────────────────────────────────────────
// Light glass vertical timeline of releases & milestones.

import { games } from "../data/games";

const doneGames = games
  .filter((g) => g.status === "done" && g.releaseDate)
  .map((g) => ({
    type: "release" as const,
    date: g.releaseDate!,
    title: g.title,
    series: g.series,
    description: g.description,
    id: g.id,
  }));

const customEvents = [
  {
    type: "event" as const,
    date: "2026-02-17",
    title: "Yakuza: Like a Dragon",
    description: "Успішно завершено збір коштів на локалізацію гри. Дякуємо всім, хто підтримав проєкт!",
    id: "yakuza-lad-fundraising-complete",
    badge: "Збір завершено",
  },
  {
    type: "event" as const,
    date: "2025-12-24",
    title: "Dispatch",
    description: "Вийшов останній епізод Dispatch. Завершено локалізацію фінальної частини гри.",
    id: "nmh-dispatch-final",
    badge: "Останній епізод",
  },
  {
    type: "event" as const,
    date: "2025-11-26",
    title: "Judgment",
    description: "Запуск раннього доступу до української локалізації.",
    id: "judgment-early-access",
    badge: "Ранній доступ",
  },
];

const releases = [...doneGames, ...customEvents]
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 15);

function formatDate(dateStr: string) {
  const date = new Date(dateStr);
  return date.toLocaleDateString("uk-UA", { day: "numeric", month: "long", year: "numeric" });
}
---

{releases.length > 0 && (
  <div class="lb-glass-strong p-6 sm:p-8" data-animate>
    <div class="mb-7">
      <h3 class="text-xl sm:text-2xl font-black text-slate-900 mb-1">Часова лінія релізів</h3>
      <p class="text-sm text-slate-500">Історія завершених локалізацій та подій</p>
    </div>

    <div class="relative">
      <div class="absolute left-[15px] top-0 bottom-0 w-0.5 bg-gradient-to-b from-indigo-400 via-sky-400 to-transparent"></div>

      <div class="space-y-6">
        {releases.map((item) => (
          <div class="relative pl-12">
            <div class="absolute left-0 top-1 w-8 h-8 rounded-full bg-white border-2 border-indigo-300 flex items-center justify-center shadow-[0_8px_18px_-10px_rgba(99,102,241,0.5)]">
              {item.type === "release" ? (
                <svg class="w-3.5 h-3.5 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              ) : (
                <svg class="w-3.5 h-3.5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              )}
            </div>

            {item.type === "release" ? (
              <button type="button" data-game-detail={item.id} class="block w-full text-left group">
                <div class="lb-glass-soft p-4 group-hover:bg-white/70 transition-colors">
                  <div class="flex items-start justify-between gap-3 mb-1.5 flex-wrap">
                    <h4 class="font-bold text-slate-900 group-hover:text-indigo-600 transition-colors line-clamp-1">
                      {item.title}
                    </h4>
                    <span class="text-xs text-slate-500 whitespace-nowrap">{formatDate(item.date)}</span>
                  </div>
                  <p class="text-xs text-slate-500 line-clamp-2">{item.description}</p>
                </div>
              </button>
            ) : (
              <div class="lb-glass-soft p-4">
                <div class="flex items-start justify-between gap-3 mb-1.5 flex-wrap">
                  <div class="flex items-center gap-2 flex-wrap">
                    <h4 class="font-bold text-slate-900 line-clamp-1">{item.title}</h4>
                    {"badge" in item && (
                      <span class="inline-flex items-center px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider rounded-md bg-amber-50 text-amber-700 border border-amber-200">
                        {item.badge}
                      </span>
                    )}
                  </div>
                  <span class="text-xs text-slate-500 whitespace-nowrap">{formatDate(item.date)}</span>
                </div>
                <p class="text-xs text-slate-500 line-clamp-2">{item.description}</p>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
)}
