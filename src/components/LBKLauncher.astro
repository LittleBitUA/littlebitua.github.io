---
// ─── LBK Launcher Section ──────────────────────────────────────
// Light glass download promo.

const features = [
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />',
    title: "Автоматичне встановлення",
    description: "Один клац — і переклад встановлено. Не потрібно нічого робити вручну.",
  },
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />',
    title: "Автооновлення",
    description: "Лаунчер сам перевіряє нові версії та сповіщає, коли вийде оновлення.",
  },
  {
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />',
    title: "Усі переклади в одному місці",
    description: "Локалізації від різних авторів — у зручному менеджері.",
  },
];
---

<section id="launcher" class="py-20 sm:py-24 relative overflow-hidden">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div data-animate>
        <span class="lb-section-eyebrow mb-5">Безкоштовно</span>
        <h2 class="text-3xl sm:text-4xl font-black text-slate-900 mt-4 mb-4 leading-tight">
          Завантажити <span class="lb-gradient-text">LBK&nbsp;Launcher</span>
        </h2>
        <p class="text-base leading-relaxed mb-8 text-slate-600 max-w-lg">
          LBK Launcher — це менеджер українських локалізацій ігор. Знаходьте, встановлюйте та оновлюйте переклади в кілька клаців, не копаючись у файлах гри вручну.
        </p>

        <a
          href="https://lbklauncher.com/"
          target="_blank" rel="noopener noreferrer"
          class="lb-btn lb-btn--primary !px-7 !py-3.5 !text-base"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Завантажити
        </a>

        <p class="text-xs text-slate-500 mt-3">Windows, macOS, Linux · Безкоштовно</p>
      </div>

      <div class="space-y-3" data-animate-stagger>
        {features.map((feature) => (
          <div class="lb-glass lb-lift p-5 flex gap-4">
            <div class="shrink-0 w-11 h-11 rounded-2xl bg-gradient-to-br from-indigo-500 to-sky-500 text-white flex items-center justify-center shadow-[0_10px_22px_-10px_rgba(99,102,241,0.55)]">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" set:html={feature.icon} />
            </div>
            <div>
              <h3 class="text-sm font-bold text-slate-900 mb-1">{feature.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed">{feature.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
