---
// ─── Support Section ───────────────────────────────────────────
// Light glass donate cards + ranked donors wall.

import DonorsWall from "./DonorsWall.astro";

const methods = [
  {
    id: "donatello",
    name: "Donatello",
    description: "Підтримайте команду разовим або регулярним донатом. Кожна гривня йде безпосередньо на локалізацію ігор.",
    url: "https://donatello.to/LittleBitUA",
    accent: "from-indigo-500 to-violet-500",
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />',
  },
  {
    id: "monobank",
    name: "Monobank",
    description: "Підтримайте через банку Monobank — зручно та швидко для українських платників.",
    url: "https://send.monobank.ua/jar/3h4akVJRXK",
    accent: "from-sky-500 to-cyan-500",
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" />',
  },
];

const reasons = [
  "Закупівля ігор для роботи над перекладами",
  "Мотивація команди продовжувати роботу",
  "Можливість працювати більше та швидше",
];
---

<section id="support" class="py-20 sm:py-24">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12" data-animate>
      <span class="lb-section-eyebrow mb-4">Підтримка</span>
      <h2 class="text-3xl sm:text-4xl font-black text-slate-900 mt-3 mb-3">
        Як підтримати команду
      </h2>
      <p class="text-slate-500 max-w-lg mx-auto">
        Ваша підтримка дозволяє нам розвивати проєкти та випускати нові переклади
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 items-start">

      <div class="lb-glass p-6 sm:p-7" data-animate>
        <h3 class="text-base font-bold text-slate-900 mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Навіщо підтримка?
        </h3>
        <ul class="space-y-3">
          {reasons.map((reason) => (
            <li class="flex items-start gap-2.5 text-sm text-slate-600">
              <span class="mt-0.5 inline-flex w-5 h-5 rounded-full bg-indigo-100 text-indigo-600 items-center justify-center shrink-0">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </span>
              {reason}
            </li>
          ))}
        </ul>
      </div>

      <div class="lg:col-span-2 grid grid-cols-1 sm:grid-cols-2 gap-5" data-animate-stagger>
        {methods.map((method) => (
          <div class="lb-glass-strong lb-lift p-6 flex flex-col justify-between gap-6 min-h-[260px]">
            <div>
              <div class={`w-12 h-12 rounded-2xl mb-4 flex items-center justify-center text-white shadow-[0_10px_22px_-10px_rgba(99,102,241,0.55)] bg-gradient-to-br ${method.accent}`}>
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" set:html={method.icon} />
              </div>
              <h3 class="text-lg font-bold text-slate-900 mb-2">{method.name}</h3>
              <p class="text-sm text-slate-600 leading-relaxed">{method.description}</p>
            </div>

            <a
              href={method.url}
              target="_blank" rel="noopener noreferrer"
              class="lb-btn lb-btn--primary"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
              Перейти до {method.name}
            </a>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-10">
      <DonorsWall />
    </div>
  </div>
</section>
