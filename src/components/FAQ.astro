---
// ─── FAQ Section ───────────────────────────────────────────────
// Light glass FAQ accordion.

const faqs = [
  {
    question: "Чи безкоштовні українські переклади від «Little Bit»?",
    answer: "Так, звичайно. Усі наші локалізації безкоштовні й завжди такими залишаться.",
  },
  {
    question: "Чи потрібна ліцензійна гра для встановлення перекладу?",
    answer: "Так, звичайно. Усі патчі тестуються лише з офіційними версіями ігор.",
  },
  {
    question: "Як оновити переклад до нової версії?",
    answer:
      "LBK Launcher автоматично перевіряє оновлення. Коли вийде нова версія перекладу, ви отримаєте сповіщення та зможете оновити в один клац.",
  },
];
---

<section id="faq" class="py-20 sm:py-24">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12" data-animate>
      <span class="lb-section-eyebrow mb-4">FAQ</span>
      <h2 class="text-3xl sm:text-4xl font-black text-slate-900 mt-3 mb-3">
        Часті питання
      </h2>
      <p class="text-slate-500 max-w-lg mx-auto">
        Відповіді на найпопулярніші запитання про переклади
      </p>
    </div>

    <div class="space-y-3" data-animate-stagger>
      {faqs.map((faq) => (
        <details class="lb-glass group p-5 sm:p-6 cursor-pointer">
          <summary class="flex items-center justify-between gap-4 text-base sm:text-lg font-bold text-slate-900 list-none">
            <span>{faq.question}</span>
            <span class="shrink-0 w-7 h-7 rounded-full bg-indigo-50 text-indigo-600 flex items-center justify-center transition-transform group-open:rotate-180">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </span>
          </summary>
          <p class="mt-3 text-sm text-slate-600 leading-relaxed">
            {faq.answer}
          </p>
        </details>
      ))}
    </div>

    <div class="mt-12 text-center" data-animate>
      <p class="text-slate-500 mb-4">Маєте інше питання?</p>
      <a
        href="https://t.me/LittleBitUA"
        target="_blank" rel="noopener noreferrer"
        class="lb-btn lb-btn--soft"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm4.64 6.8c-.15 1.58-.8 5.42-1.13 7.19-.14.75-.42 1-.68 1.03-.58.05-1.02-.38-1.58-.75-.88-.58-1.38-.94-2.23-1.5-.99-.65-.35-1.01.22-1.59.15-.15 2.71-2.48 2.76-2.69a.2.2 0 00-.05-.18c-.06-.05-.14-.03-.21-.02-.09.02-1.49.95-4.22 2.79-.4.27-.76.41-1.08.4-.36-.01-1.04-.2-1.55-.37-.63-.2-1.12-.31-1.08-.66.02-.18.27-.36.74-.55 2.92-1.27 4.86-2.11 5.83-2.51 2.78-1.16 3.35-1.36 3.73-1.36.08 0 .27.02.39.12.1.08.13.19.14.27-.01.06.01.24 0 .38z"/>
        </svg>
        Написати в Telegram
      </a>
    </div>
  </div>
</section>

<style>
  details > summary {
    list-style: none;
  }
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>
