---
// ─── How to Play / 3-step Quick Guide ──────────────────────────
// Перетворює інтерес у дію: відповідає новачку «ОК, у вас є переклади,
// що мені тепер з ними робити?» Розташована перед LBKLauncher.

interface StepDef {
  num: string;
  title: string;
  description: string;
  accent: string;
  bg: string;
  text: string;
  border: string;
  iconPath: string;
}

const STEPS: StepDef[] = [
  {
    num: "01",
    title: "Встанови LBK Launcher",
    description:
      "Один інсталер для Windows, macOS і Linux. Безкоштовно, без реклами, без зайвих кроків.",
    accent: "#0ea5e9",
    bg: "bg-sky-50",
    text: "text-sky-600",
    border: "border-sky-100",
    iconPath:
      "M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4",
  },
  {
    num: "02",
    title: "Знайди свою гру",
    description:
      "У лаунчері — каталог усіх наших перекладів. Введи назву або погортай список і обери ту, у яку гратимеш.",
    accent: "#14b8a6",
    bg: "bg-teal-50",
    text: "text-teal-600",
    border: "border-teal-100",
    iconPath:
      "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z",
  },
  {
    num: "03",
    title: "Грай українською",
    description:
      "Натисни «Встановити» — лаунчер сам додасть переклад у файли гри. Запускай через Steam звично, інтерфейс і сюжет уже українською.",
    accent: "#10b981",
    bg: "bg-emerald-50",
    text: "text-emerald-600",
    border: "border-emerald-100",
    iconPath:
      "M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  },
];
---

<section id="how-to-play" class="py-20 sm:py-24 relative">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12" data-animate>
      <span class="lb-section-eyebrow mb-4">Початок</span>
      <h2 class="text-3xl sm:text-4xl font-black text-slate-900 mt-3 mb-3">
        Як грати українською
      </h2>
      <p class="text-slate-500 max-w-xl mx-auto">
        Від встановлення лаунчера до першої сцени українською — три кроки за п'ять хвилин.
      </p>
    </div>

    <div class="relative grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
      <!-- З'єднувальна лінія між кроками (тільки на lg+) -->
      <div
        class="hidden lg:block absolute top-[60px] left-[16%] right-[16%] h-px pointer-events-none"
        style="background: linear-gradient(90deg, rgba(14,165,233,0.30), rgba(20,184,166,0.30) 50%, rgba(16,185,129,0.30));"
        aria-hidden="true"
      ></div>

      {STEPS.map((step) => (
        <div class="lb-glass lb-lift p-5 sm:p-6 flex flex-col relative" data-animate>
          <div class="flex items-center justify-between mb-4">
            <span class={`text-[11px] font-black tracking-[0.25em] ${step.text}`}>
              {step.num}
            </span>
            <div
              class={`w-11 h-11 rounded-2xl ${step.bg} ${step.text} flex items-center justify-center border border-white relative`}
              style={`box-shadow: 0 8px 18px -10px ${step.accent}80;`}
            >
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d={step.iconPath} />
              </svg>
            </div>
          </div>

          <h3 class="text-xl font-black mb-2" style={`color: ${step.accent};`}>
            {step.title}
          </h3>

          <p class="text-[13px] text-slate-600 leading-relaxed">
            {step.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
