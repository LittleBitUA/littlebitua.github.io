---
// ─── StatusBadge ──────────────────────────────────────────────
// Гнучка статусна плашка під карткою гри.
// Усі параметри тягнуться з конфігу src/data/gameBadges.ts.

import type { GameBadge } from "../data/gameBadges";

export interface Props {
  badge: GameBadge;
  /**
   * "overlay" — накладається на низ обкладинки гри (як у старій версії);
   * "card"    — окрема плашка-pill під карткою;
   * "inline"  — компактна версія, наприклад у хедері проєктної сторінки.
   */
  variant?: "overlay" | "card" | "inline";
}

const { badge, variant = "overlay" } = Astro.props;

const text = badge.text ?? "";
const label = badge.label;
const icon = badge.icon;

const color = badge.color ?? "#475569";
const textColor = badge.textColor ?? color;
const borderColor = badge.borderColor ?? `${color}55`;
const background = badge.gradient ?? badge.background ?? "rgba(255,255,255,0.55)";
const glow = badge.glow;
const opacity = badge.opacity ?? 1;
const interactive = badge.interactive ?? Boolean(badge.href);

// Visual variants share the colour API, but each picks its own structural style.
const styleObj: Record<string, string> = {
  "opacity": String(opacity),
};

if (variant === "overlay") {
  // Overlay sits on top of the cover image — recreate the old design:
  // dark-to-transparent base + accent tint on top, light text for legibility.
  const tint = badge.gradient ?? badge.background ?? `${color}30`;
  styleObj["color"] = "#ffffff";
  styleObj["background"] =
    `linear-gradient(180deg, transparent, rgba(15,23,42,0.55) 35%, rgba(15,23,42,0.78) 100%), ${tint}`;
  styleObj["border-color"] = `${color}66`;
  styleObj["text-shadow"] = "0 1px 0 rgba(0,0,0,0.55)";
  styleObj["--lb-accent"] = color;
  styleObj["box-shadow"] = glow
    ? `0 -10px 24px -8px ${glow}`
    : "none";
} else {
  styleObj["color"] = textColor;
  styleObj["background"] = background;
  styleObj["border-color"] = borderColor;
  const baseShadow = "0 1px 0 rgba(255,255,255,0.7) inset, 0 6px 18px -8px rgba(15,23,42,0.18)";
  styleObj["box-shadow"] = glow
    ? `${baseShadow}, 0 6px 24px -6px ${glow}`
    : baseShadow;
}

const style = Object.entries(styleObj).map(([k, v]) => `${k}: ${v}`).join("; ");

const Tag = badge.href ? "a" : "div";
const linkAttrs = badge.href ? { href: badge.href, target: "_blank", rel: "noopener noreferrer" } : {};

const baseClasses = [
  "lb-status-badge",
  `lb-status-badge--${variant}`,
  interactive ? "lb-status-badge--interactive" : "",
].filter(Boolean).join(" ");
---

{text && (
  <Tag class={baseClasses} style={style} aria-label={text} {...linkAttrs}>
    {variant === "overlay" && !icon && (
      <span class="lb-status-badge__dot" aria-hidden="true"></span>
    )}
    {icon && <span class="lb-status-badge__icon" aria-hidden="true">{icon}</span>}
    {label && <span class="lb-status-badge__label">{label}</span>}
    <span class="lb-status-badge__text">{text}</span>
  </Tag>
)}

<style>
  .lb-status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    border: 1px solid;
    font-weight: 700;
    letter-spacing: 0.02em;
    line-height: 1.15;
    transition: transform 0.2s ease, filter 0.2s ease;
    position: relative;
    overflow: hidden;
    text-decoration: none;
    max-width: 100%;
  }

  /* Overlay strip on cover image — flat bottom strip, full-width */
  .lb-status-badge--overlay {
    width: 100%;
    justify-content: center;
    padding: 0.5rem 0.85rem;
    font-size: 0.72rem;
    border-radius: 0;
    border-left: 0;
    border-right: 0;
    border-bottom: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* Standalone pill version (used in detail pages, etc.) */
  .lb-status-badge--card {
    width: 100%;
    justify-content: center;
    padding: 0.4rem 0.85rem;
    font-size: 0.74rem;
    border-radius: 10px;
  }

  /* Compact inline */
  .lb-status-badge--inline {
    padding: 0.32rem 0.7rem;
    font-size: 0.7rem;
    border-radius: 999px;
  }

  .lb-status-badge__dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: var(--lb-accent, currentColor);
    box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.18), 0 0 8px var(--lb-accent, currentColor);
    flex-shrink: 0;
    position: relative;
  }

  /* Pulse only on desktop / pointer-fine devices, never on touch / mobile */
  @media (hover: hover) and (pointer: fine) {
    .lb-status-badge__dot::after {
      content: "";
      position: absolute;
      inset: -2px;
      border-radius: 999px;
      background: var(--lb-accent, currentColor);
      opacity: 0;
      animation: lbDotPulse 2.4s cubic-bezier(0.4, 0, 0.2, 1) infinite;
      pointer-events: none;
    }
  }

  @keyframes lbDotPulse {
    0%   { transform: scale(1);   opacity: 0.55; }
    70%  { transform: scale(2.3); opacity: 0; }
    100% { transform: scale(2.3); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .lb-status-badge__dot::after { animation: none; opacity: 0; }
  }

  .lb-status-badge__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    font-size: 0.95em;
    flex-shrink: 0;
  }

  .lb-status-badge__label {
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.7em;
    font-weight: 700;
    opacity: 0.85;
    flex-shrink: 0;
  }

  .lb-status-badge__text {
    white-space: normal;
    text-align: center;
    word-break: break-word;
    overflow-wrap: anywhere;
  }

  @media (max-width: 640px) {
    .lb-status-badge--overlay {
      font-size: 0.66rem;
      padding: 0.45rem 0.75rem;
      letter-spacing: 0.06em;
    }
    .lb-status-badge--card {
      font-size: 0.72rem;
      padding: 0.5rem 0.85rem;
    }
  }

  .lb-status-badge--interactive {
    cursor: pointer;
  }

  @media (hover: hover) {
    .lb-status-badge--interactive:hover {
      transform: translateY(-1px);
      filter: saturate(1.1) brightness(1.03);
    }
  }
</style>
