---
// ─── FilterBar ─────────────────────────────────────────────────
// Search, status filter, sort. Light glass styling.

import { getStatusList, STATUS_LABELS } from "../data/games";
const statusList = getStatusList();
---

<div class="lb-glass p-4 sm:p-5 mb-8" data-animate>
  <div class="flex flex-col gap-4">

    <!-- Search + counter -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3">
      <div class="relative w-full sm:flex-1 sm:max-w-md">
        <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 pointer-events-none"
             fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          type="text"
          id="search-input"
          placeholder="Пошук за назвою, серією, тегами..."
          class="w-full pl-10 pr-4 py-2.5 text-sm rounded-xl border
                 bg-white/65 border-white/80 text-slate-900 placeholder-slate-400
                 focus:outline-none focus:border-indigo-300 focus:bg-white/90 focus:ring-4 focus:ring-indigo-100
                 transition-all"
        />
      </div>

      <span id="results-counter" class="text-xs font-semibold text-slate-500">
        Завантаження...
      </span>

      <button
        id="reset-all"
        class="hidden items-center gap-1.5 px-3.5 py-2 text-xs font-bold rounded-xl
               bg-rose-50 border border-rose-200 text-rose-600 hover:bg-rose-100"
      >
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
        Скинути все
      </button>

      <!-- Sort -->
      <div class="relative ml-auto">
        <select
          id="sort-select"
          class="appearance-none pl-3.5 pr-9 py-2.5 text-xs font-bold rounded-xl border
                 bg-white/65 border-white/80 text-slate-700
                 hover:bg-white/90 focus:outline-none focus:border-indigo-300
                 cursor-pointer"
        >
          <option value="default">За замовчуванням</option>
          <option value="progress-desc">Прогрес ↓</option>
          <option value="progress-asc">Прогрес ↑</option>
          <option value="title-asc">Назва (А→Я)</option>
          <option value="title-desc">Назва (Я→А)</option>
          <option value="update-desc">Останні оновлення</option>
        </select>
        <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-3 h-3 text-slate-500 pointer-events-none"
             fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </div>
    </div>

    <!-- Status pills -->
    <div class="flex flex-wrap gap-2" id="filter-bar">
      <button class="filter-btn active" data-filter="status" data-value="all">Усі статуси</button>
      {statusList.map((status) => (
        <button class="filter-btn" data-filter="status" data-value={status}>
          {STATUS_LABELS[status]}
        </button>
      ))}
    </div>

    <!-- Active tag indicator -->
    <div id="active-tag-filter" class="hidden">
      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-lg bg-indigo-50 border border-indigo-200 text-indigo-700">
        <span>Тег:</span>
        <span id="active-tag-label"></span>
        <button id="clear-tag-filter" class="hover:text-indigo-900" aria-label="Скинути">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </span>
    </div>
  </div>
</div>

<style>
  .filter-btn {
    padding: 0.45rem 0.95rem;
    font-size: 0.72rem;
    font-weight: 700;
    border-radius: 999px;
    border: 1px solid rgba(15, 23, 42, 0.10);
    background: rgba(255, 255, 255, 0.7);
    color: #475569;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
    cursor: pointer;
    white-space: nowrap;
  }
  .filter-btn:hover {
    background: rgba(255, 255, 255, 0.95);
    border-color: rgba(99, 102, 241, 0.35);
    color: #0f172a;
    transform: translateY(-1px);
  }
  .filter-btn.active {
    background-color: #6366f1;
    background-image: none;
    color: #fff;
    border-color: transparent;
    box-shadow: 0 8px 18px -10px rgba(99, 102, 241, 0.55);
  }
  .filter-btn.active:hover {
    background-color: #6366f1;
    background-image: none;
    color: #fff;
    border-color: transparent;
    transform: none;
  }
  #reset-all.inline-flex { display: inline-flex; }
  #active-tag-filter.inline-flex { display: inline-flex; }
</style>

<script>
  import Fuse from "fuse.js";

  const searchInput = document.getElementById("search-input") as HTMLInputElement;
  const sortSelect = document.getElementById("sort-select") as HTMLSelectElement;
  const filterBar = document.getElementById("filter-bar")!;
  const statusButtons = filterBar.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const resultsCounter = document.getElementById("results-counter")!;
  const resetAllBtn = document.getElementById("reset-all")!;
  const activeTagEl = document.getElementById("active-tag-filter")!;
  const activeTagLabel = document.getElementById("active-tag-label")!;
  const clearTagBtn = document.getElementById("clear-tag-filter")!;

  const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-game-id]"));

  let currentStatus = "all";
  let currentSearch = "";
  let currentTag = "";
  let currentSort = "default";

  const gamesList = cards.map((card, idx) => ({
    element: card,
    originalIndex: idx,
    title: card.dataset.title || "",
    series: card.dataset.series || "",
    tags: card.dataset.tags || "",
    status: card.dataset.status || "",
    progress: parseInt(card.dataset.progress || "0", 10),
    lastUpdate: card.dataset.lastUpdate || "",
  }));

  const fuse = new Fuse(gamesList, {
    keys: ["title", "series", "tags"],
    threshold: 0.3,
    includeScore: true,
  });

  function applyFilters() {
    let filtered = gamesList;
    if (currentSearch.trim()) filtered = fuse.search(currentSearch).map((r) => r.item);
    if (currentStatus !== "all") filtered = filtered.filter((g) => g.status === currentStatus);
    if (currentTag) filtered = filtered.filter((g) => g.tags.toLowerCase().includes(currentTag.toLowerCase()));

    filtered.sort((a, b) => {
      switch (currentSort) {
        case "progress-desc": return b.progress - a.progress;
        case "progress-asc":  return a.progress - b.progress;
        case "title-asc":     return a.title.localeCompare(b.title, "uk");
        case "title-desc":    return b.title.localeCompare(a.title, "uk");
        case "update-desc":   return b.lastUpdate.localeCompare(a.lastUpdate);
        default:              return a.originalIndex - b.originalIndex;
      }
    });

    const filteredIds = new Set(filtered.map((g) => g.element.dataset.gameId));
    cards.forEach((card) => {
      const show = filteredIds.has(card.dataset.gameId);
      if (show) {
        card.style.display = "";
        card.style.order = filtered.findIndex((g) => g.element === card).toString();
        setTimeout(() => {
          card.style.opacity = "1";
          card.style.transform = "translateY(0)";
        }, 30);
      } else {
        card.style.opacity = "0";
        card.style.transform = "translateY(12px)";
        setTimeout(() => { card.style.display = "none"; }, 250);
      }
    });

    resultsCounter.textContent = `Знайдено: ${filtered.length} з ${cards.length}`;

    const hasActive = currentSearch || currentStatus !== "all" || currentTag;
    if (hasActive) {
      resetAllBtn.classList.remove("hidden");
      resetAllBtn.classList.add("inline-flex");
    } else {
      resetAllBtn.classList.add("hidden");
      resetAllBtn.classList.remove("inline-flex");
    }
  }

  let searchTimeout: ReturnType<typeof setTimeout>;
  searchInput.addEventListener("input", () => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      currentSearch = searchInput.value;
      applyFilters();
    }, 250);
  });

  statusButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      statusButtons.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      currentStatus = btn.dataset.value || "all";
      applyFilters();
    });
  });

  sortSelect.addEventListener("change", () => {
    currentSort = sortSelect.value;
    applyFilters();
  });

  resetAllBtn.addEventListener("click", () => {
    currentSearch = "";
    currentStatus = "all";
    currentTag = "";
    currentSort = "default";
    searchInput.value = "";
    sortSelect.value = "default";
    statusButtons.forEach((b) => b.classList.remove("active"));
    statusButtons[0].classList.add("active");
    activeTagEl.classList.add("hidden");
    activeTagEl.classList.remove("inline-flex");
    applyFilters();
  });

  document.addEventListener("click", (e) => {
    const tagEl = (e.target as HTMLElement).closest("[data-tag-filter]") as HTMLElement | null;
    if (!tagEl) return;
    const tag = tagEl.dataset.tagFilter || "";
    currentTag = tag;
    activeTagLabel.textContent = tag;
    activeTagEl.classList.remove("hidden");
    activeTagEl.classList.add("inline-flex");
    applyFilters();
  });

  clearTagBtn.addEventListener("click", () => {
    currentTag = "";
    activeTagEl.classList.add("hidden");
    activeTagEl.classList.remove("inline-flex");
    applyFilters();
  });

  applyFilters();
</script>
