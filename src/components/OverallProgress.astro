---
// ─── OverallProgress Section ───────────────────────────────────
// Light glass aggregate progress display.

import ProgressBar from "./ProgressBar.astro";
import { games, getOverallProgress, STATUS_LABELS } from "../data/games";

const overall = getOverallProgress();
const R = 52;
const C = 2 * Math.PI * R;
const progressOffset = C * (1 - overall / 100);
const sorted = [...games].sort((a, b) => b.progress - a.progress);

const STATUS_PILL: Record<string, string> = {
  done: "text-emerald-700 bg-emerald-50 border-emerald-200",
  "early-access": "text-sky-700 bg-sky-50 border-sky-200",
  "in-progress": "text-violet-700 bg-violet-50 border-violet-200",
  fundraising: "text-amber-700 bg-amber-50 border-amber-200",
  planned: "text-slate-700 bg-slate-50 border-slate-200",
};
---

<section id="progress" class="py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12" data-animate>
      <span class="lb-section-eyebrow mb-4">Аналітика</span>
      <h2 class="text-3xl sm:text-4xl font-black text-slate-900 mt-3 mb-3">
        Загальний прогрес
      </h2>
      <p class="text-slate-500 max-w-lg mx-auto">
        Середній прогрес перекладу по всіх проєктах
      </p>
    </div>

    <div class="lb-glass-strong p-6 sm:p-10" data-animate>
      <div class="grid lg:grid-cols-[280px_1fr] gap-10 items-start">
        <!-- Ring -->
        <div class="flex flex-col items-center">
          <div class="relative w-48 h-48 mb-3">
            <svg class="w-full h-full -rotate-90" viewBox="0 0 120 120">
              <defs>
                <linearGradient id="overallGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#6366f1" />
                  <stop offset="60%" stop-color="#0ea5e9" />
                  <stop offset="100%" stop-color="#a78bfa" />
                </linearGradient>
              </defs>
              <circle cx="60" cy="60" r={R} fill="none" stroke="rgba(15,23,42,0.06)" stroke-width="9" />
              <circle cx="60" cy="60" r={R} fill="none" stroke="url(#overallGradient)" stroke-width="9"
                      stroke-linecap="round" stroke-dasharray={C} stroke-dashoffset={C}
                      class="overall-ring" style={`--ring-target: ${progressOffset}`} />
            </svg>
            <div class="absolute inset-0 flex items-center justify-center flex-col">
              <span class="text-4xl font-black text-slate-900 tabular-nums overall-counter" data-target={overall}>0%</span>
              <span class="text-[11px] font-bold uppercase tracking-[0.16em] text-slate-500 mt-1">з {games.length} проєктів</span>
            </div>
          </div>
          <p class="text-sm text-slate-500 text-center">Середній прогрес усіх проєктів</p>
        </div>

        <div class="space-y-3 max-h-[450px] overflow-y-auto pr-2 lb-scroll" data-animate-stagger>
          {sorted.map((game) => (
            <div class="flex items-center gap-4 px-2 py-1.5 rounded-xl hover:bg-white/55 transition-colors">
              <a href={`/projects/${game.id}`} class="w-44 text-sm font-medium text-slate-700 truncate shrink-0 hover:text-indigo-600 transition-colors">
                {game.title}
              </a>
              <div class="flex-1 min-w-0">
                <ProgressBar percent={game.progress} showLabel={false} size="sm" />
              </div>
              <div class="flex items-center gap-2 shrink-0">
                <span class="text-sm font-bold text-slate-900 tabular-nums w-10 text-right">{game.progress}%</span>
                <span class={`text-[10px] font-bold px-2 py-0.5 rounded-full border ${STATUS_PILL[game.status]}`}>
                  {STATUS_LABELS[game.status]}
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .overall-ring { transition: stroke-dashoffset 1.8s cubic-bezier(0.16, 1, 0.3, 1); }
  .overall-ring.animate { stroke-dashoffset: var(--ring-target) !important; }
  .lb-scroll::-webkit-scrollbar { width: 6px; }
  .lb-scroll::-webkit-scrollbar-thumb { background: rgba(99,102,241,0.3); border-radius: 999px; }
</style>

<script>
  const section = document.getElementById("progress");
  if (section) {
    const ring = section.querySelector(".overall-ring");
    const counter = section.querySelector(".overall-counter") as HTMLSpanElement | null;
    let animated = false;
    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !animated) {
            animated = true;
            if (ring) ring.classList.add("animate");
            if (counter) {
              const target = parseInt(counter.dataset.target || "0", 10);
              const duration = 1800;
              const start = performance.now();
              const tick = (now: number) => {
                const elapsed = now - start;
                const progress = Math.min(elapsed / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 3);
                counter.textContent = `${Math.round(eased * target)}%`;
                if (progress < 1) requestAnimationFrame(tick);
              };
              requestAnimationFrame(tick);
            }
          }
        });
      },
      { threshold: 0.3 }
    );
    obs.observe(section);
  }
</script>
