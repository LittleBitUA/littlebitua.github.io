---
// ─── Available Now ────────────────────────────────────────────
// Hero-adjacent strip that answers the visitor's first question:
// "What can I actually play in Ukrainian right now?"
// Pulls games with status `done` or `early-access`, picks the most
// recently updated as the featured cover, the rest fill the mosaic.

import { games } from "../data/games";

const available = games
  .filter((g) => g.status === "done" || g.status === "early-access")
  .sort((a, b) => (b.lastUpdate ?? "").localeCompare(a.lastUpdate ?? ""));

const featured = available[0];
const others = available.slice(1, 7); // up to 6 smaller covers (7 total in mosaic)

const doneCount = available.filter((g) => g.status === "done").length;
const earlyCount = available.filter((g) => g.status === "early-access").length;
const totalCount = available.length;
---

{featured && (
  <section id="available-now" class="pt-24 pb-12 sm:pt-32 sm:pb-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="lb-glass-strong rounded-3xl p-6 sm:p-10 lg:p-12 lb-available">
        <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.35fr)] gap-8 lg:gap-12 items-center">

          <!-- Left: copy + CTAs -->
          <div data-animate>
            <span class="lb-section-eyebrow mb-3">Грай зараз</span>
            <h2 class="text-3xl sm:text-4xl font-black text-slate-900 leading-tight mt-3 mb-3">
              {totalCount} ігор, у які можна грати<br/>українською вже сьогодні
            </h2>
            <p class="text-slate-600 text-base sm:text-lg leading-relaxed mb-5 max-w-md">
              Готові та доступні в ранньому доступі локалізації — встановлюються
              одним клацом через LBK Launcher і оновлюються самі.
            </p>

            <ul class="space-y-2 mb-7 text-sm sm:text-base text-slate-700">
              <li class="flex items-start gap-2.5">
                <span class="mt-1 inline-flex w-4 h-4 rounded-full bg-emerald-100 text-emerald-600 items-center justify-center shrink-0">
                  <svg class="w-2.5 h-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                  </svg>
                </span>
                <span><b class="tabular-nums">{doneCount}</b> повністю готові — з релізом локалізації</span>
              </li>
              <li class="flex items-start gap-2.5">
                <span class="mt-1 inline-flex w-4 h-4 rounded-full bg-sky-100 text-sky-600 items-center justify-center shrink-0">
                  <svg class="w-2.5 h-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                  </svg>
                </span>
                <span><b class="tabular-nums">{earlyCount}</b> у ранньому доступі — грай і отримуй оновлення</span>
              </li>
              <li class="flex items-start gap-2.5">
                <span class="mt-1 inline-flex w-4 h-4 rounded-full bg-indigo-100 text-indigo-600 items-center justify-center shrink-0">
                  <svg class="w-2.5 h-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                  </svg>
                </span>
                <span>Один лаунчер — усі переклади одним клацом</span>
              </li>
            </ul>

            <div class="flex flex-wrap items-center gap-2.5">
              <a href="/#launcher" class="lb-btn lb-btn--primary">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                </svg>
                Встановити LBK Launcher
              </a>
              <a href="/projects" class="lb-btn lb-btn--ghost">
                Усі готові
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>

          <!-- Right: cover mosaic -->
          <div class="lb-available__mosaic" data-animate-stagger>
            <button
              type="button"
              data-game-detail={featured.id}
              class="lb-mosaic-cover lb-mosaic-cover--featured"
              aria-label={`Деталі: ${featured.title}`}
            >
              <img src={featured.cover} alt={featured.title} loading="lazy" decoding="async" />
              <span class={`lb-mosaic-cover__dot ${featured.status === "done" ? "is-done" : "is-early"}`} aria-hidden="true"></span>
              <span class="lb-mosaic-cover__caption">
                <span class="lb-mosaic-cover__status">
                  {featured.status === "done" ? "Готово" : "Ранній доступ"}
                </span>
                <span class="lb-mosaic-cover__title">{featured.title}</span>
              </span>
            </button>

            {others.map((g) => (
              <button
                type="button"
                data-game-detail={g.id}
                class="lb-mosaic-cover"
                aria-label={`Деталі: ${g.title}`}
              >
                <img src={g.cover} alt={g.title} loading="lazy" decoding="async" />
                <span class={`lb-mosaic-cover__dot ${g.status === "done" ? "is-done" : "is-early"}`} aria-hidden="true"></span>
                <span class="lb-mosaic-cover__title-overlay">{g.title}</span>
              </button>
            ))}
          </div>

        </div>
      </div>
    </div>
  </section>
)}

<style>
  .lb-available__mosaic {
    display: grid;
    /* 4 cols × 2 rows: first column wider so the featured cover keeps a
       natural 2:3 portrait ratio when spanning both rows. */
    grid-template-columns: minmax(0, 2fr) repeat(3, minmax(0, 1fr));
    grid-template-rows: auto auto;
    gap: 8px;
  }

  /* On the smallest screens, lose one column rather than crush the covers. */
  @media (max-width: 480px) {
    .lb-available__mosaic {
      grid-template-columns: minmax(0, 2fr) repeat(2, minmax(0, 1fr));
    }
    /* Hide the last small cover so the bottom row stays tidy at 2 smalls */
    .lb-available__mosaic > .lb-mosaic-cover:nth-child(n + 6) {
      display: none;
    }
  }

  .lb-mosaic-cover {
    position: relative;
    display: block;
    aspect-ratio: 2 / 3;
    border-radius: 14px;
    overflow: hidden;
    cursor: pointer;
    background: rgba(15, 23, 42, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.6);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.85) inset,
      0 10px 22px -16px rgba(15, 23, 42, 0.35);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .lb-mosaic-cover--featured {
    grid-row: span 2;
    /* Let the doubled row-span dictate height; image fills via object-fit. */
    aspect-ratio: auto;
  }

  .lb-mosaic-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .lb-mosaic-cover:hover {
    transform: translateY(-3px);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.9) inset,
      0 18px 36px -16px rgba(15, 23, 42, 0.45),
      0 8px 16px -12px rgba(99, 102, 241, 0.30);
  }
  .lb-mosaic-cover:hover img {
    transform: scale(1.06);
  }

  /* Status dot — top-right corner */
  .lb-mosaic-cover__dot {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 10px;
    height: 10px;
    border-radius: 999px;
    box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.85);
    z-index: 2;
  }
  .lb-mosaic-cover__dot.is-done {
    background: #10b981;
    box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.85), 0 0 12px rgba(16, 185, 129, 0.5);
  }
  .lb-mosaic-cover__dot.is-early {
    background: #0ea5e9;
    box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.85), 0 0 12px rgba(14, 165, 233, 0.5);
  }

  /* Title-only overlay for smaller covers, only visible on hover */
  .lb-mosaic-cover__title-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: 0.55rem 0.65rem;
    background: linear-gradient(180deg, transparent 45%, rgba(15, 23, 42, 0.82) 100%);
    color: #fff;
    font-family: "Manrope", "Inter", system-ui, sans-serif;
    font-weight: 700;
    font-size: 0.78rem;
    line-height: 1.2;
    text-align: left;
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
  }
  .lb-mosaic-cover:hover .lb-mosaic-cover__title-overlay {
    opacity: 1;
  }

  /* Featured cover always shows a small caption block at the bottom */
  .lb-mosaic-cover__caption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 0.85rem 0.95rem 0.95rem;
    background: linear-gradient(180deg, transparent, rgba(15, 23, 42, 0.92));
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    pointer-events: none;
  }
  .lb-mosaic-cover__status {
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.75);
  }
  .lb-mosaic-cover__title {
    font-family: "Manrope", "Inter", system-ui, sans-serif;
    font-weight: 800;
    font-size: 0.95rem;
    line-height: 1.2;
    color: #fff;
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.3);
  }
</style>
