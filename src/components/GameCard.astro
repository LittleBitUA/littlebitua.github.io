---
// ─── GameCard ─────────────────────────────────────────────────
// White liquid glass game card with cover, status, progress, actions.
// Status labels under the card are loaded from src/data/gameBadges.ts.

import ProgressBar from "./ProgressBar.astro";
import Tag from "./Tag.astro";
import StatusBadge from "./StatusBadge.astro";
import type { Game } from "../data/games";
import { STATUS_LABELS } from "../data/games";
import { getBadge } from "../data/gameBadges";
import "@fortawesome/fontawesome-free/css/all.css";

export interface Props {
  game: Game;
}

const { game } = Astro.props;
const hasDetails = game.stageDetails && game.stageDetails.length > 0;
const badge = getBadge(game.id);

// Top-of-cover status pill (from game data, kept dynamic)
const topPillLabel = game.status === "fundraising"
  ? STATUS_LABELS.fundraising
  : (game.status === "early-access" ? STATUS_LABELS["early-access"]
    : (game.status === "done" ? STATUS_LABELS.done
      : (game.status === "in-progress" ? STATUS_LABELS["in-progress"] : STATUS_LABELS.planned)));

const topPillColor =
  game.status === "done" ? "text-emerald-700 bg-emerald-100/85 border-emerald-200" :
  game.status === "early-access" ? "text-sky-700 bg-sky-100/85 border-sky-200" :
  game.status === "in-progress" ? "text-violet-700 bg-violet-100/85 border-violet-200" :
  game.status === "fundraising" ? "text-amber-700 bg-amber-100/90 border-amber-200" :
  "text-slate-700 bg-white/85 border-white/70";
---

<article
  class="game-card group relative flex flex-col"
  data-game-id={game.id}
  data-series={game.series}
  data-status={game.status}
  data-title={game.title}
  data-tags={game.tags.join(",")}
  data-progress={game.progress}
  data-platform={game.platform?.join(",") || ""}
  data-translation-size={game.translationSize || ""}
  data-game-year={game.gameYear || 0}
  data-last-update={game.lastUpdate || ""}
  data-animate
>
  <div class="lb-glass lb-lift flex flex-col flex-1 overflow-hidden">

    <!-- Cover (Steam 2:3) -->
    <div class="relative aspect-[2/3] overflow-hidden">
      <img
        src={game.cover}
        alt={game.title}
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
        decoding="async"
      />
      {!badge && (
        <div class="absolute inset-0 bg-gradient-to-t from-slate-900/40 via-transparent to-transparent"></div>
      )}

      <!-- Top-left status pill -->
      <div class="absolute top-2.5 left-2.5 z-10">
        <span class={`inline-flex items-center gap-1 px-2.5 py-1 text-[10px] font-bold rounded-full border ${topPillColor}`}>
          {game.status === "done" && (
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          )}
          {(game.status === "early-access" || game.status === "in-progress") && (
            <span class="w-1.5 h-1.5 rounded-full bg-current animate-pulse"></span>
          )}
          {game.status === "fundraising" && (<span class="text-xs font-bold leading-none">₴</span>)}
          {topPillLabel}
        </span>
      </div>

      <!-- Top-right percent -->
      <div class="absolute top-2.5 right-2.5 z-10">
        <span
          class="px-2.5 py-1 text-xs font-extrabold tabular-nums text-white rounded-lg"
          style="background: rgba(15, 23, 42, 0.78); box-shadow: 0 0 0 1px rgba(255,255,255,0.18) inset, 0 6px 14px -6px rgba(15,23,42,0.6); text-shadow: 0 1px 0 rgba(0,0,0,0.4);"
        >
          {game.progress}<span class="text-[10px] font-medium opacity-70">%</span>
        </span>
      </div>

      <!-- Status badge overlaid on the cover bottom (config-driven) -->
      {badge && (
        <div class="absolute bottom-0 left-0 right-0 z-10">
          <StatusBadge badge={badge} variant="overlay" />
        </div>
      )}
    </div>

    <!-- Content -->
    <div class="p-4 sm:p-5 flex flex-col flex-1">
      <h3 class="text-base font-bold leading-snug mb-2 line-clamp-2 text-slate-900">
        <a href={`/projects/${game.id}`} class="hover:text-indigo-600 transition-colors">
          {game.title}
        </a>
      </h3>

      <p class="card-desc text-[13px] leading-relaxed mb-3 line-clamp-2 flex-1 text-slate-600 transition-all">
        {game.description}
      </p>

      <!-- Progress -->
      <div class="mb-3">
        {hasDetails ? (
          <div class="game-progress-toggle cursor-pointer" data-expanded="false">
            <div class="flex items-center gap-2">
              <div class="flex-1">
                <ProgressBar percent={game.progress} size="sm" showLabel={false} />
              </div>
              <button
                type="button"
                class="expand-btn flex-shrink-0 w-6 h-6 rounded-md bg-white/70 border border-white/80
                       flex items-center justify-center text-slate-500 hover:text-indigo-600 hover:bg-white"
                aria-label="Деталі прогресу"
              >
                <svg class="w-3.5 h-3.5 expand-icon transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
            </div>

            <div class="stage-details overflow-hidden max-h-0 transition-all duration-300 ease-in-out">
              <div class="pt-3 space-y-1.5">
                {game.stageDetails!.map((detail) => (
                  <div class="flex items-center gap-2">
                    <span class="text-[10px] font-semibold text-slate-500 w-[68px] flex-shrink-0 truncate">
                      {detail.label}
                    </span>
                    <div class="flex-1 h-1 rounded-full bg-slate-200/70 overflow-hidden">
                      <div
                        class="h-full rounded-full transition-all duration-500"
                        style={`width: ${detail.percent}%; background: ${detail.percent >= 100 ? "#16a34a" : detail.percent > 0 ? "linear-gradient(90deg,#6366f1,#0ea5e9)" : "rgba(100,116,139,0.6)"};`}
                      ></div>
                    </div>
                    <span class="text-[10px] font-bold tabular-nums text-slate-700 w-[28px] text-right">
                      {detail.percent}%
                    </span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <ProgressBar percent={game.progress} size="sm" showLabel={false} />
        )}
      </div>

      <!-- Tags -->
      <div class="flex flex-wrap gap-1.5 mb-4">
        {game.tags.slice(0, 4).map((tag) => <Tag label={tag} />)}
      </div>

      <!-- Details button -->
      <a
        href={`/projects/${game.id}`}
        class="lb-btn lb-btn--ghost !py-2 !text-xs w-full"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        Детальніше
      </a>

      <!-- Action row -->
      <div class="flex items-center gap-1.5 mt-2">
        {game.downloadUrl ? (
          <a
            href={game.downloadUrl}
            target="_blank" rel="noopener noreferrer"
            class="flex-1 lb-btn !py-2 !text-xs"
            style="color:#15803d; background: rgba(34,197,94,0.10); border: 1px solid rgba(34,197,94,0.3);"
          >
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
            </svg>
            Завантажити
          </a>
        ) : (
          <span
            class="flex-1 lb-btn !py-2 !text-xs cursor-not-allowed"
            style="color: #94a3b8; background: rgba(148,163,184,0.12); border: 1px solid rgba(148,163,184,0.25);"
          >
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Скоро
          </span>
        )}

        {game.steamUrl && (
          <a
            href={game.steamUrl}
            target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center justify-center w-9 h-9 rounded-xl border bg-white/65 text-slate-600 border-white/70 hover:bg-white hover:text-slate-900 transition-colors"
            aria-label="Сторінка в Steam"
          >
            <i class="fa-brands fa-steam"></i>
          </a>
        )}

        {(game.status === "fundraising" || game.fundraisingGoal) && (
          <a
            href={game.donateUrl}
            target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center justify-center w-9 h-9 rounded-xl border bg-amber-50 text-amber-700 border-amber-200 hover:bg-amber-100 transition-colors"
            aria-label="Підтримати збір"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
          </a>
        )}
      </div>
    </div>
  </div>
</article>

<script>
  document.querySelectorAll(".game-progress-toggle").forEach((toggle) => {
    const btn = toggle.querySelector(".expand-btn");
    const icon = toggle.querySelector(".expand-icon");
    const details = toggle.querySelector(".stage-details") as HTMLElement;
    if (!btn || !icon || !details) return;

    const card = toggle.closest("article");
    const desc = card?.querySelector(".card-desc");

    const handleClick = (e: Event) => {
      e.stopPropagation();
      const expanded = toggle.getAttribute("data-expanded") === "true";
      toggle.setAttribute("data-expanded", String(!expanded));
      if (!expanded) {
        details.style.maxHeight = details.scrollHeight + "px";
        icon.classList.add("rotate-180");
        desc?.classList.remove("line-clamp-2");
      } else {
        details.style.maxHeight = "0px";
        icon.classList.remove("rotate-180");
        desc?.classList.add("line-clamp-2");
      }
    };

    btn.addEventListener("click", handleClick);
    toggle.addEventListener("click", handleClick);
  });
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
